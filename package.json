{
  "name": "origam",
  "version": "2.5.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "description": "origam monorepo — Vue 3 design system (lib + marketing + stories + docs + tests + figma plugin). Workspace root, not published. The publishable package lives in packages/ds.",
  "license": "MIT",
  "author": "Prioul Arnaud",
  "homepage": "https://github.com/arnaudprioul/origam#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arnaudprioul/origam.git"
  },
  "bugs": {
    "url": "https://github.com/arnaudprioul/origam/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:lib": "pnpm -F origam build",
    "build:marketing": "pnpm -F @origam/marketing build",
    "build:stories": "pnpm -F @origam/stories build",
    "build:docs": "pnpm -F @origam/docs build",
    "build:figma": "pnpm -F @origam/figma-plugin build",
    "build:all": "pnpm -r build",
    "tokens:build": "pnpm -F origam tokens:build",
    "tokens:watch": "pnpm -F origam tokens:watch",
    "tokens:lint": "pnpm -F origam tokens:lint",
    "dev:stories": "pnpm -F @origam/stories dev",
    "dev:docs": "pnpm -F @origam/docs dev",
    "dev:marketing": "pnpm -F @origam/marketing dev",
    "test:unit": "pnpm -F @origam/tests test:unit",
    "test:unit:run": "pnpm -F @origam/tests test:unit:run",
    "test:run": "pnpm -F @origam/tests test:unit:run",
    "test:e2e": "pnpm -F @origam/tests test:e2e",
    "test:a11y": "pnpm -F @origam/tests test:a11y",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --max-warnings 0",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
