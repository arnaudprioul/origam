; histoire@1.0.0-alpha.2 declares a peer dep on vite ^6, but origam runs
; on vite ^7 — they're functionally compatible, the alpha just hasn't
; been re-published. `legacy-peer-deps=true` lets `npm install` proceed
; without `--legacy-peer-deps` having to be remembered everywhere
; (CI, onboarding, Tokens Studio sync action, dev machines).
;
; Drop this file once histoire ships a vite-7-compatible release.
legacy-peer-deps=true

; Strict engines off — node 22 is required (.nvmrc) but we don't want
; npm to refuse to install for a contributor running 20 (node 20+ has
; everything except the @vitejs/plugin-vue crypto.hash usage we already
; document in CLAUDE.md).
engine-strict=false

; pnpm monorepo settings
auto-install-peers=true
strict-peer-dependencies=false

; CRITICAL: with `"origam": "*"` (npm/yarn-compatible), pnpm by default
; resolves to the latest version on the registry instead of the workspace
; package. This caused marketing to load origam@2.5.0 from npm instead
; of packages/ds/ (workspace), breaking the `./styles` export.
; `link-workspace-packages=deep` forces pnpm to prefer the workspace
; package whenever its version satisfies the range — including `*`.
; npm and yarn already prefer workspace packages by default, so this
; setting only matters for pnpm.
link-workspace-packages=deep
prefer-workspace-packages=true
