{
  "name": "@origam/marketing",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "origam — Nuxt 4 marketing site. Phase 1: landing page on the origam default theme.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare || [ \"$CI\" = \"true\" ]",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "docs:generate": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs --files",
    "docs:generate:check": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs --files --check",
    "docs:dump": "tsx --tsconfig ./tsconfig.typeorm.json scripts/dump-db-fixture.mjs",
    "docs:playgrounds": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-playgrounds.mjs",
    "docs:seed": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs --seed",
    "docs:seed:check": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs --seed --check",
    "docs:sync": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs",
    "docs:sync:check": "tsx --tsconfig ./tsconfig.typeorm.json scripts/generate-api-docs.mjs --check",
    "presets:generate": "node scripts/generate-brand-presets.mjs",
    "presets:generate:check": "node scripts/generate-brand-presets.mjs --check",
    "db:migrate": "tsx --tsconfig ./tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:run -d ./server/db/data-source.cli.ts",
    "db:rollback": "tsx --tsconfig ./tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:revert -d ./server/db/data-source.cli.ts",
    "db:migrate:status": "tsx --tsconfig ./tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:show -d ./server/db/data-source.cli.ts",
    "db:migrate:make": "tsx --tsconfig ./tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:generate -d ./server/db/data-source.cli.ts"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.0.0",
    "@nuxtjs/seo": "^5.3.2",
    "@vue/repl": "^4.4.0",
    "nuxt": "^4.4.7",
    "origam": "workspace:*",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.0.0"
  }
}
