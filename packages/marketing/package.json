{
  "name": "@origam/marketing",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "origam — Nuxt 4 marketing site. Phase 1: landing page on the origam default theme.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare || [ \"$CI\" = \"true\" ]",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "docs:generate": "node scripts/generate-api-docs.mjs --files",
    "docs:generate:check": "node scripts/generate-api-docs.mjs --files --check",
    "docs:seed": "node scripts/generate-api-docs.mjs --seed",
    "docs:seed:check": "node scripts/generate-api-docs.mjs --seed --check",
    "docs:sync": "node scripts/generate-api-docs.mjs",
    "docs:sync:check": "node scripts/generate-api-docs.mjs --check",
    "presets:generate": "node scripts/generate-brand-presets.mjs",
    "presets:generate:check": "node scripts/generate-brand-presets.mjs --check",
    "db:migrate": "node server/db/migrate.mjs run",
    "db:rollback": "node server/db/migrate.mjs revert",
    "db:migrate:status": "node server/db/migrate.mjs show"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.0.0",
    "@nuxtjs/seo": "^2.0.0",
    "@vue/repl": "^4.4.0",
    "nuxt": "^4.0.0",
    "origam": "workspace:*",
    "pg": "^8.22.0",
    "typeorm": "^1.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vue-tsc": "^3.0.0"
  }
}
