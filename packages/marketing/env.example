# -----------------------------------------------------------------------------
# Marketing site — environment for docker-compose and the API-Reference DB.
# Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.
# -----------------------------------------------------------------------------

# --- PostgreSQL (the `db` compose service + the host port mapping) -----------
DB_USER=origam
DB_PASSWORD=origam
DB_NAME=origam_docs
# Host port the DB is exposed on (container is always 5432).
DB_PORT=5432

# --- App ---------------------------------------------------------------------
# Host port the Nuxt/Nitro server is exposed on (container is always 3000).
APP_PORT=3000
NUXT_PUBLIC_GITHUB_REPO=arnaudprioul/origam

# -----------------------------------------------------------------------------
# How the connection is resolved (see server/db/connection.mjs):
#   DATABASE_URL takes precedence; the discrete DB_HOST/DB_PORT/DB_USER/
#   DB_PASSWORD/DB_NAME are the fallback. Inside compose, the app + migrate
#   services derive DATABASE_URL pointing at the `db` service automatically.
#
# For host-run tooling (db:migrate / docs:seed / docs:sync) against the compose
# DB, export:
#   DATABASE_URL=postgres://origam:origam@127.0.0.1:5432/origam_docs
#
# Add DB_SSL=true for a managed Postgres that presents a self-signed chain.
# -----------------------------------------------------------------------------
