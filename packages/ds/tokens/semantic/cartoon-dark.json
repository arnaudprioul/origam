{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#1A1A1A" },
      "raised":    { "$type": "color", "$value": "#262626" },
      "overlay":   { "$type": "color", "$value": "#3D2E0A" },
      "sunken":    { "$type": "color", "$value": "#0F0F0F" },
      "disabled":  { "$type": "color", "$value": "#262626" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#FFFEFB" },
      "secondary": { "$type": "color", "$value": "#D4D4D4" },
      "disabled":  { "$type": "color", "$value": "#737373" },
      "inverse":   { "$type": "color", "$value": "#171717" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "#FFFEFB" },
      "subtle":   { "$type": "color", "$value": "#FFFEFB" },
      "strong":   { "$type": "color", "$value": "#FFFFFF" },
      "focus":    { "$type": "color", "$value": "#A78BFA" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#A78BFA" },
        "bgHover":    { "$type": "color", "$value": "#C4B5FD" },
        "bgSubtle":   { "$type": "color", "$value": "#5B21B6" },
        "bgDisabled": { "$type": "color", "$value": "#404040" },
        "fg":         { "$type": "color", "$value": "#171717" },
        "fgSubtle":   { "$type": "color", "$value": "#C4B5FD" },
        "fgDisabled": { "$type": "color", "$value": "#737373" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "#FCD34D" },
        "bgHover":    { "$type": "color", "$value": "#FBBF24" },
        "bgDisabled": { "$type": "color", "$value": "#404040" },
        "fg":         { "$type": "color", "$value": "#171717" },
        "fgDisabled": { "$type": "color", "$value": "#737373" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "rgba(255,254,251,0.10)" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#A78BFA" },
        "fgDisabled": { "$type": "color", "$value": "#737373" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#4ADE80" },
        "bgSubtle": { "$type": "color", "$value": "#14532D" },
        "fg":       { "$type": "color", "$value": "#171717" },
        "fgSubtle": { "$type": "color", "$value": "#86EFAC" },
        "border":   { "$type": "color", "$value": "#FFFEFB" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#FBBF24" },
        "bgSubtle": { "$type": "color", "$value": "#78350F" },
        "fg":       { "$type": "color", "$value": "#171717" },
        "fgSubtle": { "$type": "color", "$value": "#FCD34D" },
        "border":   { "$type": "color", "$value": "#FFFEFB" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#F87171" },
        "bgSubtle": { "$type": "color", "$value": "#7F1D1D" },
        "fg":       { "$type": "color", "$value": "#171717" },
        "fgSubtle": { "$type": "color", "$value": "#FCA5A5" },
        "border":   { "$type": "color", "$value": "#FFFEFB" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#60A5FA" },
        "bgSubtle": { "$type": "color", "$value": "#1E3A8A" },
        "fg":       { "$type": "color", "$value": "#171717" },
        "fgSubtle": { "$type": "color", "$value": "#93C5FD" },
        "border":   { "$type": "color", "$value": "#FFFEFB" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#000000" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "14px" },
    "lg": { "$type": "dimension", "$value": "20px" }
  },
  "border": {
    "width": {
      "thin": { "$type": "dimension", "$value": "2.5px" },
      "2":    { "$type": "dimension", "$value": "2.5px" }
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px",  "offsetY": "0px",  "blur": "0px", "spread": "0px", "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "2px",  "offsetY": "2px",  "blur": "0px", "spread": "0px", "color": "#FFFEFB" } },
    "sm":   { "$type": "shadow", "$value": { "offsetX": "4px",  "offsetY": "4px",  "blur": "0px", "spread": "0px", "color": "#FFFEFB" } },
    "md":   { "$type": "shadow", "$value": { "offsetX": "4px",  "offsetY": "4px",  "blur": "0px", "spread": "0px", "color": "#FFFEFB" } },
    "lg":   { "$type": "shadow", "$value": { "offsetX": "6px",  "offsetY": "6px",  "blur": "0px", "spread": "0px", "color": "#FFFEFB" } },
    "xl":   { "$type": "shadow", "$value": { "offsetX": "8px",  "offsetY": "8px",  "blur": "0px", "spread": "0px", "color": "#FFFEFB" } }
  }
}
