{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#0A0A0A" },
      "raised":    { "$type": "color", "$value": "#0E0E0E" },
      "overlay":   { "$type": "color", "$value": "#171717" },
      "sunken":    { "$type": "color", "$value": "#050505" },
      "disabled":  { "$type": "color", "$value": "#1A1A1A" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#FAFAFA" },
      "secondary": { "$type": "color", "$value": "#A3A3A3" },
