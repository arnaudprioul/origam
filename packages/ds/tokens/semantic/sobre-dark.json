      "inverse":   { "$type": "color", "$value": "#0A0A0A" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "rgba(255,255,255,0.08)" },
