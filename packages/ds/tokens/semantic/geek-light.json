{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#F0FDF4" },
      "raised":    { "$type": "color", "$value": "#FFFFFF" },
      "overlay":   { "$type": "color", "$value": "#DCFCE7" },
      "sunken":    { "$type": "color", "$value": "#E6FAEC" },
      "disabled":  { "$type": "color", "$value": "#DCFCE7" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#14532D" },
      "secondary": { "$type": "color", "$value": "#166534" },
      "disabled":  { "$type": "color", "$value": "#86EFAC" },
      "inverse":   { "$type": "color", "$value": "#FFFFFF" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "rgba(22,101,52,0.20)" },
      "subtle":   { "$type": "color", "$value": "rgba(22,101,52,0.08)" },
      "strong":   { "$type": "color", "$value": "rgba(22,101,52,0.45)" },
      "focus":    { "$type": "color", "$value": "#16A34A" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#15803D" },
        "bgHover":    { "$type": "color", "$value": "#166534" },
        "bgSubtle":   { "$type": "color", "$value": "rgba(22,163,74,0.10)" },
        "bgDisabled": { "$type": "color", "$value": "#DCFCE7" },
        "fg":         { "$type": "color", "$value": "#F0FDF4" },
        "fgSubtle":   { "$type": "color", "$value": "#166534" },
        "fgDisabled": { "$type": "color", "$value": "#86EFAC" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "#DCFCE7" },
        "bgHover":    { "$type": "color", "$value": "#BBF7D0" },
        "bgDisabled": { "$type": "color", "$value": "#E6FAEC" },
        "fg":         { "$type": "color", "$value": "#14532D" },
        "fgDisabled": { "$type": "color", "$value": "#86EFAC" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "rgba(22,101,52,0.08)" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#15803D" },
        "fgDisabled": { "$type": "color", "$value": "#86EFAC" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#16A34A" },
        "bgSubtle": { "$type": "color", "$value": "rgba(22,163,74,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#15803D" },
        "border":   { "$type": "color", "$value": "#16A34A" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#D97706" },
        "bgSubtle": { "$type": "color", "$value": "rgba(217,119,6,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B45309" },
        "border":   { "$type": "color", "$value": "#D97706" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#DC2626" },
        "bgSubtle": { "$type": "color", "$value": "rgba(220,38,38,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B91C1C" },
        "border":   { "$type": "color", "$value": "#DC2626" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#2563EB" },
        "bgSubtle": { "$type": "color", "$value": "rgba(37,99,235,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#1D4ED8" },
        "border":   { "$type": "color", "$value": "#2563EB" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#14532D" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "2px" },
    "md": { "$type": "dimension", "$value": "4px" },
    "lg": { "$type": "dimension", "$value": "4px" },
    "full": { "$type": "dimension", "$value": "4px" }
  },
  "font": {
    "family": {
      "sans":  { "$type": "fontFamily", "$value": "JetBrains Mono, Fira Code, ui-monospace, monospace" },
      "serif": { "$type": "fontFamily", "$value": "JetBrains Mono, Fira Code, ui-monospace, monospace" }
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px",  "spread": "0px", "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "4px",  "spread": "0px", "color": "rgba(74,222,128,0.35)" } },
    "sm":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "8px",  "spread": "0px", "color": "rgba(74,222,128,0.50)" } },
    "md":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "12px", "spread": "2px", "color": "rgba(74,222,128,0.45)" } },
    "lg":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "20px", "spread": "4px", "color": "rgba(74,222,128,0.55)" } },
    "xl":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "32px", "spread": "6px", "color": "rgba(74,222,128,0.60)" } }
  }
}
