{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#FFFFFF" },
      "raised":    { "$type": "color", "$value": "#FAFAFA" },
      "overlay":   { "$type": "color", "$value": "#F5F5F5" },
      "sunken":    { "$type": "color", "$value": "#F0F0F0" },
      "disabled":  { "$type": "color", "$value": "#E6E6E6" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#0A0A0A" },
      "secondary": { "$type": "color", "$value": "#525252" },
      "disabled":  { "$type": "color", "$value": "#A3A3A3" },
      "inverse":   { "$type": "color", "$value": "#FFFFFF" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "rgba(0,0,0,0.08)" },
      "subtle":   { "$type": "color", "$value": "rgba(0,0,0,0.04)" },
      "strong":   { "$type": "color", "$value": "rgba(0,0,0,0.16)" },
      "focus":    { "$type": "color", "$value": "#7C3AED" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#7C3AED" },
        "bgHover":    { "$type": "color", "$value": "#6D28D9" },
        "bgSubtle":   { "$type": "color", "$value": "rgba(124,58,237,0.10)" },
        "bgDisabled": { "$type": "color", "$value": "#E6E6E6" },
        "fg":         { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle":   { "$type": "color", "$value": "#6D28D9" },
        "fgDisabled": { "$type": "color", "$value": "#A3A3A3" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "#F5F5F5" },
        "bgHover":    { "$type": "color", "$value": "#E6E6E6" },
        "bgDisabled": { "$type": "color", "$value": "#FAFAFA" },
        "fg":         { "$type": "color", "$value": "#171717" },
        "fgDisabled": { "$type": "color", "$value": "#A3A3A3" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "rgba(0,0,0,0.06)" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#7C3AED" },
        "fgDisabled": { "$type": "color", "$value": "#A3A3A3" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#16A34A" },
        "bgSubtle": { "$type": "color", "$value": "rgba(22,163,74,0.08)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#15803D" },
        "border":   { "$type": "color", "$value": "#16A34A" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#D97706" },
        "bgSubtle": { "$type": "color", "$value": "rgba(217,119,6,0.08)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B45309" },
        "border":   { "$type": "color", "$value": "#D97706" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#DC2626" },
        "bgSubtle": { "$type": "color", "$value": "rgba(220,38,38,0.08)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B91C1C" },
        "border":   { "$type": "color", "$value": "#DC2626" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#2563EB" },
        "bgSubtle": { "$type": "color", "$value": "rgba(37,99,235,0.08)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#1D4ED8" },
        "border":   { "$type": "color", "$value": "#2563EB" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#000000" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "14px" }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px",  "spread": "0px", "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px", "color": "rgba(0,0,0,0.04)" } },
    "sm":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "4px",  "spread": "0px", "color": "rgba(0,0,0,0.06)" } },
    "md":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "8px",  "spread": "0px", "color": "rgba(0,0,0,0.06)" } },
    "lg":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "16px", "spread": "0px", "color": "rgba(0,0,0,0.07)" } },
    "xl":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "28px", "spread": "0px", "color": "rgba(0,0,0,0.08)" } }
  }
}
