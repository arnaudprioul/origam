{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#000000" },
      "raised":    { "$type": "color", "$value": "#1C1C1E" },
      "overlay":   { "$type": "color", "$value": "#2C2C2E" },
      "sunken":    { "$type": "color", "$value": "#0A0A0B" },
      "disabled":  { "$type": "color", "$value": "#1C1C1E" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#F5F5F7" },
      "secondary": { "$type": "color", "$value": "#A1A1A6" },
      "disabled":  { "$type": "color", "$value": "#6E6E73" },
      "inverse":   { "$type": "color", "$value": "#1D1D1F" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "#38383A" },
      "subtle":   { "$type": "color", "$value": "#2C2C2E" },
      "strong":   { "$type": "color", "$value": "#6E6E73" },
      "focus":    { "$type": "color", "$value": "#0A84FF" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#0A84FF" },
        "bgHover":    { "$type": "color", "$value": "#409CFF" },
        "bgSubtle":   { "$type": "color", "$value": "rgba(10,132,255,0.16)" },
        "bgDisabled": { "$type": "color", "$value": "#1C1C1E" },
        "fg":         { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle":   { "$type": "color", "$value": "#64B5FF" },
        "fgDisabled": { "$type": "color", "$value": "#6E6E73" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "#2C2C2E" },
        "bgHover":    { "$type": "color", "$value": "#3A3A3C" },
        "bgDisabled": { "$type": "color", "$value": "#1C1C1E" },
        "fg":         { "$type": "color", "$value": "#F5F5F7" },
        "fgDisabled": { "$type": "color", "$value": "#6E6E73" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "rgba(255,255,255,0.08)" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#0A84FF" },
        "fgDisabled": { "$type": "color", "$value": "#6E6E73" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#30D158" },
        "bgSubtle": { "$type": "color", "$value": "rgba(48,209,88,0.16)" },
        "fg":       { "$type": "color", "$value": "#000000" },
        "fgSubtle": { "$type": "color", "$value": "#64E47C" },
        "border":   { "$type": "color", "$value": "#30D158" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#FF9F0A" },
        "bgSubtle": { "$type": "color", "$value": "rgba(255,159,10,0.16)" },
        "fg":       { "$type": "color", "$value": "#000000" },
        "fgSubtle": { "$type": "color", "$value": "#FFB445" },
        "border":   { "$type": "color", "$value": "#FF9F0A" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#FF453A" },
        "bgSubtle": { "$type": "color", "$value": "rgba(255,69,58,0.16)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#FF6961" },
        "border":   { "$type": "color", "$value": "#FF453A" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#0A84FF" },
        "bgSubtle": { "$type": "color", "$value": "rgba(10,132,255,0.16)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#64B5FF" },
        "border":   { "$type": "color", "$value": "#0A84FF" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#000000" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "18px" },
    "full": { "$type": "dimension", "$value": "980px" }
  },
  "font": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": "-apple-system, BlinkMacSystemFont, SF Pro Display, Inter, sans-serif" }
    }
  }
}
