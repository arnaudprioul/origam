{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#F5F3FF" },
      "raised":    { "$type": "color", "$value": "rgba(255,255,255,0.65)" },
      "overlay":   { "$type": "color", "$value": "rgba(255,255,255,0.85)" },
      "sunken":    { "$type": "color", "$value": "#EDE9FE" },
      "disabled":  { "$type": "color", "$value": "rgba(255,255,255,0.45)" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#1E1B4B" },
      "secondary": { "$type": "color", "$value": "#5B21B6" },
      "disabled":  { "$type": "color", "$value": "#A78BFA" },
      "inverse":   { "$type": "color", "$value": "#FFFFFF" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "rgba(124,58,237,0.20)" },
      "subtle":   { "$type": "color", "$value": "rgba(124,58,237,0.10)" },
      "strong":   { "$type": "color", "$value": "rgba(124,58,237,0.35)" },
      "focus":    { "$type": "color", "$value": "#7C3AED" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#7C3AED" },
        "bgHover":    { "$type": "color", "$value": "#6D28D9" },
        "bgSubtle":   { "$type": "color", "$value": "rgba(124,58,237,0.10)" },
        "bgDisabled": { "$type": "color", "$value": "rgba(167,139,250,0.30)" },
        "fg":         { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle":   { "$type": "color", "$value": "#6D28D9" },
        "fgDisabled": { "$type": "color", "$value": "#A78BFA" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "rgba(255,255,255,0.70)" },
        "bgHover":    { "$type": "color", "$value": "rgba(255,255,255,0.90)" },
        "bgDisabled": { "$type": "color", "$value": "rgba(255,255,255,0.40)" },
        "fg":         { "$type": "color", "$value": "#1E1B4B" },
        "fgDisabled": { "$type": "color", "$value": "#A78BFA" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "rgba(124,58,237,0.08)" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#7C3AED" },
        "fgDisabled": { "$type": "color", "$value": "#A78BFA" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#16A34A" },
        "bgSubtle": { "$type": "color", "$value": "rgba(22,163,74,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#15803D" },
        "border":   { "$type": "color", "$value": "#16A34A" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#D97706" },
        "bgSubtle": { "$type": "color", "$value": "rgba(217,119,6,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B45309" },
        "border":   { "$type": "color", "$value": "#D97706" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#DC2626" },
        "bgSubtle": { "$type": "color", "$value": "rgba(220,38,38,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#B91C1C" },
        "border":   { "$type": "color", "$value": "#DC2626" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#2563EB" },
        "bgSubtle": { "$type": "color", "$value": "rgba(37,99,235,0.10)" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#1D4ED8" },
        "border":   { "$type": "color", "$value": "#2563EB" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#1E1B4B" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "10px" },
    "md": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "22px" }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px",  "blur": "0px",  "spread": "0px",  "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px",  "blur": "16px", "spread": "0px",  "color": "rgba(124,58,237,0.10)" } },
    "sm":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px",  "blur": "24px", "spread": "0px",  "color": "rgba(124,58,237,0.15)" } },
    "md":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "12px", "blur": "36px", "spread": "-2px", "color": "rgba(124,58,237,0.18)" } },
    "lg":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "20px", "blur": "60px", "spread": "-4px", "color": "rgba(124,58,237,0.22)" } },
    "xl":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "28px", "blur": "80px", "spread": "-6px", "color": "rgba(124,58,237,0.28)" } }
  }
}
