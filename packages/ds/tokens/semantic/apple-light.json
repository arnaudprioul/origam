{
  "color": {
    "surface": {
      "default":   { "$type": "color", "$value": "#FFFFFF" },
      "raised":    { "$type": "color", "$value": "#FBFBFD" },
      "overlay":   { "$type": "color", "$value": "#F5F5F7" },
      "sunken":    { "$type": "color", "$value": "#F2F2F4" },
      "disabled":  { "$type": "color", "$value": "#F5F5F7" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#1D1D1F" },
      "secondary": { "$type": "color", "$value": "#515154" },
      "disabled":  { "$type": "color", "$value": "#86868B" },
      "inverse":   { "$type": "color", "$value": "#FFFFFF" },
      "onColor":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default":  { "$type": "color", "$value": "#D2D2D7" },
      "subtle":   { "$type": "color", "$value": "#E5E5E7" },
      "strong":   { "$type": "color", "$value": "#86868B" },
      "focus":    { "$type": "color", "$value": "#0071E3" }
    },
    "action": {
      "primary": {
        "bg":         { "$type": "color", "$value": "#0071E3" },
        "bgHover":    { "$type": "color", "$value": "#0077ED" },
        "bgSubtle":   { "$type": "color", "$value": "#F0F7FF" },
        "bgDisabled": { "$type": "color", "$value": "#E5E5E7" },
        "fg":         { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle":   { "$type": "color", "$value": "#0058B0" },
        "fgDisabled": { "$type": "color", "$value": "#86868B" }
      },
      "secondary": {
        "bg":         { "$type": "color", "$value": "#F5F5F7" },
        "bgHover":    { "$type": "color", "$value": "#E5E5E7" },
        "bgDisabled": { "$type": "color", "$value": "#FBFBFD" },
        "fg":         { "$type": "color", "$value": "#1D1D1F" },
        "fgDisabled": { "$type": "color", "$value": "#86868B" }
      },
      "ghost": {
        "bg":         { "$type": "color", "$value": "transparent" },
        "bgHover":    { "$type": "color", "$value": "#F5F5F7" },
        "bgDisabled": { "$type": "color", "$value": "transparent" },
        "fg":         { "$type": "color", "$value": "#0071E3" },
        "fgDisabled": { "$type": "color", "$value": "#86868B" }
      }
    },
    "feedback": {
      "success": {
        "bg":       { "$type": "color", "$value": "#28CD41" },
        "bgSubtle": { "$type": "color", "$value": "#E8F8EC" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#198529" },
        "border":   { "$type": "color", "$value": "#28CD41" }
      },
      "warning": {
        "bg":       { "$type": "color", "$value": "#FF9F0A" },
        "bgSubtle": { "$type": "color", "$value": "#FFF4E5" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#A86600" },
        "border":   { "$type": "color", "$value": "#FF9F0A" }
      },
      "danger": {
        "bg":       { "$type": "color", "$value": "#FF3B30" },
        "bgSubtle": { "$type": "color", "$value": "#FFE9E7" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#C2271C" },
        "border":   { "$type": "color", "$value": "#FF3B30" }
      },
      "info": {
        "bg":       { "$type": "color", "$value": "#0071E3" },
        "bgSubtle": { "$type": "color", "$value": "#F0F7FF" },
        "fg":       { "$type": "color", "$value": "#FFFFFF" },
        "fgSubtle": { "$type": "color", "$value": "#0058B0" },
        "border":   { "$type": "color", "$value": "#0071E3" }
      }
    },
    "overlay": {
      "scrim": { "$type": "color", "$value": "#1D1D1F" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "18px" },
    "full": { "$type": "dimension", "$value": "980px" }
  },
  "font": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": "-apple-system, BlinkMacSystemFont, SF Pro Display, Inter, sans-serif" }
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px",  "spread": "0px", "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "3px",  "spread": "0px", "color": "rgba(0,0,0,0.10)" } },
    "sm":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "6px",  "spread": "0px", "color": "rgba(0,0,0,0.10)" } },
    "md":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "14px", "spread": "-1px","color": "rgba(0,0,0,0.12)" } },
    "lg":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "-2px","color": "rgba(0,0,0,0.14)" } },
    "xl":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "14px","blur": "40px", "spread": "-4px","color": "rgba(0,0,0,0.16)" } }
  }
}
