  "space": {
    "0":  { "$type": "dimension", "$value": "0px" },
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "8":  { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "14": { "$type": "dimension", "$value": "56px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" }
  },
  "font": {
    "family": {
      "sans":  { "$type": "fontFamily", "$value": "Inter, Helvetica Neue, Arial, sans-serif" },
      "mono":  { "$type": "fontFamily", "$value": "JetBrains Mono, Fira Code, monospace" },
      "serif": { "$type": "fontFamily", "$value": "Georgia, Times New Roman, serif" }
    },
    "size": {
      "xs":  { "$type": "dimension", "$value": "0.625rem" },
      "sm":  { "$type": "dimension", "$value": "0.75rem" },
      "md":  { "$type": "dimension", "$value": "0.875rem" },
      "lg":  { "$type": "dimension", "$value": "1rem" },
      "xl":  { "$type": "dimension", "$value": "1.125rem" },
      "2xl": { "$type": "dimension", "$value": "1.25rem" },
      "3xl": { "$type": "dimension", "$value": "1.5rem" },
      "4xl": { "$type": "dimension", "$value": "1.875rem" },
      "5xl": { "$type": "dimension", "$value": "2.25rem" }
    },
    "weight": {
      "regular":   { "$type": "fontWeight", "$value": 400 },
      "medium":    { "$type": "fontWeight", "$value": 500 },
      "semibold":  { "$type": "fontWeight", "$value": 600 },
      "bold":      { "$type": "fontWeight", "$value": 700 },
      "extrabold": { "$type": "fontWeight", "$value": 800 },
      "black":     { "$type": "fontWeight", "$value": 900 }
    },
    "lineHeight": {
      "none":    { "$type": "number", "$value": 1 },
      "tight":   { "$type": "number", "$value": 1.25 },
      "snug":    { "$type": "number", "$value": 1.375 },
      "normal":  { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.625 },
      "loose":   { "$type": "number", "$value": 2 }
    },
    "letterSpacing": {
      "tight":   { "$type": "dimension", "$value": "-0.025em" },
      "normal":  { "$type": "dimension", "$value": "0em" },
      "wide":    { "$type": "dimension", "$value": "0.009375em" },
      "wider":   { "$type": "dimension", "$value": "0.0125em" },
      "widest":  { "$type": "dimension", "$value": "0.0892857143em" }
    }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "12px" },
    "xl":   { "$type": "dimension", "$value": "16px" },
    "2xl":  { "$type": "dimension", "$value": "24px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px", "color": "rgba(0,0,0,0)" } },
    "xs":   { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(0,0,0,0.05)" } },
    "sm":   { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px", "color": "rgba(0,0,0,0.1)" },
      { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "-1px", "color": "rgba(0,0,0,0.1)" }
    ]},
    "md":   { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "6px", "blur": "24px", "spread": "0px", "color": "rgba(0,0,0,0.05)" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px", "color": "rgba(0,0,0,0.08)" }
    ]},
    "lg":   { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "5px", "blur": "5px", "spread": "-3px", "color": "rgba(0,0,0,0.2)" },
      { "offsetX": "0px", "offsetY": "8px", "blur": "10px", "spread": "1px", "color": "rgba(0,0,0,0.14)" },
      { "offsetX": "0px", "offsetY": "3px", "blur": "14px", "spread": "2px", "color": "rgba(0,0,0,0.12)" }
    ]},
    "xl":   { "$type": "shadow", "$value": [
      { "offsetX": "0px", "offsetY": "11px", "blur": "15px", "spread": "-7px", "color": "rgba(0,0,0,0.2)" },
      { "offsetX": "0px", "offsetY": "24px", "blur": "38px", "spread": "3px", "color": "rgba(0,0,0,0.14)" },
      { "offsetX": "0px", "offsetY": "9px", "blur": "46px", "spread": "8px", "color": "rgba(0,0,0,0.12)" }
    ]}
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fast":    { "$type": "duration", "$value": "100ms" },
      "normal":  { "$type": "duration", "$value": "150ms" },
      "medium":  { "$type": "duration", "$value": "200ms" },
      "slow":    { "$type": "duration", "$value": "280ms" },
      "xslow":   { "$type": "duration", "$value": "400ms" }
    },
    "easing": {
      "standard":   { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
      "decelerate": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "accelerate": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "sharp":      { "$type": "cubicBezier", "$value": [0.4, 0, 0.6, 1] },
      "linear":     { "$type": "cubicBezier", "$value": [0, 0, 1, 1] }
    }
  },
  "zIndex": {
    "base":     { "$type": "number", "$value": 0 },
    "raised":   { "$type": "number", "$value": 1 },
    "dropdown": { "$type": "number", "$value": 1000 },
    "sticky":   { "$type": "number", "$value": 1020 },
    "fixed":    { "$type": "number", "$value": 1030 },
    "overlay":  { "$type": "number", "$value": 1040 },
    "modal":    { "$type": "number", "$value": 1050 },
    "toast":    { "$type": "number", "$value": 1060 },
    "tooltip":  { "$type": "number", "$value": 1070 }
  },
  "opacity": {
    "0":   { "$type": "number", "$value": 0 },
    "12":  { "$type": "number", "$value": 0.12 },
    "26":  { "$type": "number", "$value": 0.26 },
    "32":  { "$type": "number", "$value": 0.32 },
    "50":  { "$type": "number", "$value": 0.5 },
    "60":  { "$type": "number", "$value": 0.6 },
    "70":  { "$type": "number", "$value": 0.7 },
    "87":  { "$type": "number", "$value": 0.87 },
    "100": { "$type": "number", "$value": 1 }
  },
  "border": {
    "width": {
      "0":    { "$type": "dimension", "$value": "0px" },
      "thin": { "$type": "dimension", "$value": "1px" },
      "2":    { "$type": "dimension", "$value": "2px" },
      "4":    { "$type": "dimension", "$value": "4px" }
    },
    "style": {
      "solid":  { "$type": "other", "$value": "solid" },
      "dashed": { "$type": "other", "$value": "dashed" },
      "dotted": { "$type": "other", "$value": "dotted" }
    }
  }
