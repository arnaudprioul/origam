{
  "sound": {
    "background-color":           { "$type": "color",      "$value": "{color.neutral.50}" },
    "color":                      { "$type": "color",      "$value": "{color.neutral.900}" },
    "padding":                    { "$type": "dimension",  "$value": "{space.3}" },
    "border-radius":              { "$type": "dimension",  "$value": "{radius.md}" },
    "gap":                        { "$type": "dimension",  "$value": "{space.3}" },

    "body": {
      "gap":                      { "$type": "dimension",  "$value": "{space.2}" }
    },

    "cover": {
      "size":                     { "$type": "dimension",  "$value": "{space.20}" },
      "border-radius":            { "$type": "dimension",  "$value": "{radius.md}" }
    },

    "metadata": {
      "gap":                      { "$type": "dimension",  "$value": "{space.1}" }
    },

    "title": {
      "color":                    { "$type": "color",      "$value": "{color.neutral.900}" },
      "font-size":                { "$type": "dimension",  "$value": "{font.size.md}" },
      "font-weight":              { "$type": "fontWeight", "$value": "{font.weight.semibold}" }
    },

    "artist": {
      "color":                    { "$type": "color",      "$value": "{color.neutral.700}" },
      "font-size":                { "$type": "dimension",  "$value": "{font.size.sm}" }
    },

    "album": {
      "color":                    { "$type": "color",      "$value": "{color.neutral.500}" },
      "font-size":                { "$type": "dimension",  "$value": "{font.size.xs}" }
    },

    "controls": {
      "gap":                      { "$type": "dimension",  "$value": "{space.2}" },
      "icon-color":               { "$type": "color",      "$value": "{color.neutral.700}" },
      "icon-color-hover":         { "$type": "color",      "$value": "{color.neutral.900}" }
    },

    "btn": {
      "size":                     { "$type": "dimension",  "$value": "{space.8}" },
      "border-radius":            { "$type": "dimension",  "$value": "{radius.sm}" },
      "font-size":                { "$type": "dimension",  "$value": "{font.size.lg}" },
      "background-color-hover":   { "$type": "color",      "$value": "{color.neutral.100}" }
    },

    "time": {
      "color":                    { "$type": "color",      "$value": "{color.neutral.700}" },
      "font-size":                { "$type": "dimension",  "$value": "{font.size.xs}" },
      "font-family":              { "$type": "fontFamily", "$value": "{font.family.mono}" }
    },

    "scrubber": {
      "color":                    { "$type": "color",      "$value": "{color.primary.500}" },
      "thumb-color":              { "$type": "color",      "$value": "{color.primary.700}" }
    },

    "volume": {
      "color":                    { "$type": "color",      "$value": "{color.neutral.500}" },
      "width":                    { "$type": "dimension",  "$value": "{space.20}" }
    },

    "waveform": {
      "height":                   { "$type": "dimension",  "$value": "{space.10}" },
      "color-played":             { "$type": "color",      "$value": "{color.primary.500}" },
      "color-unplayed":           { "$type": "color",      "$value": "{color.neutral.300}" },
      "bar-width":                { "$type": "dimension",  "$value": "{space.1}" },
      "bar-gap":                  { "$type": "dimension",  "$value": "{space.1}" }
    }
  }
}
