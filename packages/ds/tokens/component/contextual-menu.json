{
  "contextual-menu": {
    "background":              { "$type": "color",      "$value": "{color.surface.raised}",
                                 "$description": "Inherits from menu.background — contextual-menu is a specialised menu variant." },
    "color":                   { "$type": "color",      "$value": "{color.text.primary}" },
    "border-radius":           { "$type": "dimension",  "$value": "{radius.md}" },
    "box-shadow":              { "$type": "shadow",     "$value": "{shadow.lg}" },
    "z-index":                 { "$type": "number",     "$value": "{zIndex.dropdown}",
                                 "$description": "= 1000. Contextual menus appear above content but below modal-level surfaces." },
    "max-height":              { "$type": "other",      "$value": "calc(100vh - 32px)" },
    "position":                { "$type": "other",      "$value": "fixed",
                                 "$description": "Target 'cursor' — the overlay positions this element at cursor coordinates via the connected locationStrategy." },

    "transition-duration":     { "$type": "duration",   "$value": "{motion.duration.fast}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.decelerate}" },

    "content": {
      "padding":               { "$type": "dimension",  "$value": "{space.1}" },
      "max-width":             { "$type": "dimension",  "$value": "320px" },
      "overflow":              { "$type": "other",      "$value": "auto" }
    },

    "offset-top":              { "$type": "dimension",  "$value": "{space.2}" },
    "offset-bottom":           { "$type": "dimension",  "$value": "{space.2}" },
    "offset-left":             { "$type": "dimension",  "$value": "{space.0}" },
    "offset-right":            { "$type": "dimension",  "$value": "{space.0}" }
  }
}
