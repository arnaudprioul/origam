{
  "color-picker-field": {
    "_comment": "Field + ColorPicker integration. Inherits field.json chrome; adds the color swatch shown inside the input.",
    "min-width":  { "$type": "dimension", "$value": "200px" },

    "swatch": {
      "width":         { "$type": "dimension", "$value": "24px" },
      "height":        { "$type": "dimension", "$value": "24px" },
      "border-radius": { "$type": "dimension", "$value": "{radius.sm}" },
      "border-color":  { "$type": "color",     "$value": "{color.border.subtle}" },
      "border-width":  { "$type": "dimension", "$value": "{border.width.thin}" }
    },

    "icon": {
      "color":       { "$type": "color", "$value": "{color.text.secondary}" },
      "color-hover": { "$type": "color", "$value": "{color.text.primary}" }
    }
  }
}
