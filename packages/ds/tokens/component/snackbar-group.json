{
  "snackbar-group": {
    "z-index":                 { "$type": "number",     "$value": "{zIndex.toast}" },
    "gap":                     { "$type": "dimension",  "$value": "{space.3}" },
    "max-width":               { "$type": "dimension",  "$value": "420px" },
    "transition-duration":     { "$type": "duration",   "$value": "{motion.duration.fast}" },
    "position-top":            { "$type": "dimension",  "$value": "{space.4}" },
    "position-bottom":         { "$type": "dimension",  "$value": "{space.4}" },
    "position-left":           { "$type": "dimension",  "$value": "{space.4}" },
    "position-right":          { "$type": "dimension",  "$value": "{space.4}" },

    "item": {
      "gap":                   { "$type": "dimension",  "$value": "{space.3}" },
      "min-width":             { "$type": "dimension",  "$value": "288px" },
      "max-width":             { "$type": "dimension",  "$value": "420px" },
      "padding":               { "$type": "other",      "$value": "12px 14px" },
      "border-radius":         { "$type": "dimension",  "$value": "{radius.md}" },
      "border-width":          { "$type": "dimension",  "$value": "{border.width.thin}" },
      "background-color":      { "$type": "color",      "$value": "{color.surface.default}" },
      "border-color":          { "$type": "color",      "$value": "{color.border.subtle}" },
      "color":                 { "$type": "color",      "$value": "{color.text.primary}" },
      "box-shadow":            { "$type": "other",      "$value": "{shadow.md}" },
      "font-size":             { "$type": "dimension",  "$value": "{font.size.md}" },
      "content-gap":           { "$type": "dimension",  "$value": "{space.2}" },
      "prepend-color":         { "$type": "color",      "$value": "currentColor" },
      "text-gap":              { "$type": "dimension",  "$value": "{space.1}" },
      "title-font-weight":     { "$type": "fontWeight", "$value": "{font.weight.semibold}" },
      "message-font-weight":   { "$type": "fontWeight", "$value": "{font.weight.regular}" },
      "message-color":         { "$type": "color",      "$value": "currentColor" },
      "message-opacity":       { "$type": "number",     "$value": 0.85 },
      "action-color":          { "$type": "color",      "$value": "{color.action.primary.fg}" }
    }
  }
}
