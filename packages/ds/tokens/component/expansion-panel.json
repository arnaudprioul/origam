{
  "expansion-panel": {
    "background":              { "$type": "color",     "$value": "{color.surface.raised}" },
    "color":                   { "$type": "color",     "$value": "{color.text.primary}" },
    "border-radius":           { "$type": "dimension", "$value": "{radius.sm}" },
    "border-color":            { "$type": "color",     "$value": "{color.border.subtle}" },
    "border-style":            { "$type": "other",     "$value": "solid" },
    "border-top-width":        { "$type": "dimension", "$value": "{border.width.0}" },
    "border-left-width":       { "$type": "dimension", "$value": "{border.width.0}" },
    "border-bottom-width":     { "$type": "dimension", "$value": "{border.width.0}" },
    "border-right-width":      { "$type": "dimension", "$value": "{border.width.0}" },
    "flex":                    { "$type": "other",     "$value": "1 0 100%" },
    "max-width":               { "$type": "other",     "$value": "100%" },
    "position":                { "$type": "other",     "$value": "relative" },
    "transition-duration":     { "$type": "duration",  "$value": "{motion.duration.slow}" },
    "transition-property":     { "$type": "other",     "$value": "margin-top, border-radius, border, max-width" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },

    "divider-color":           { "$type": "color",     "$value": "{color.border.subtle}",
                                 "$description": "Color of the ::after separator between panels (not accordion variant)" },
    "divider-opacity":         { "$type": "number",    "$value": "{opacity.12}",
                                 "$description": "Opacity of the separator between panels. Literal 0.12 applied in scoped style." },
    "active-margin-top":       { "$type": "dimension", "$value": "{space.4}" },

    "disabled-color":          { "$type": "color",     "$value": "{color.text.disabled}" },
    "disabled-pointer-events": { "$type": "other",     "$value": "none" },
    "disabled-overlay-opacity":{ "$type": "number",    "$value": "{opacity.60}",
                                 "$description": "Computed as 0.4615384615 in source — aliased to opacity.60 (nearest primitive)" },

    "shadow": {
      "position":              { "$type": "other",     "$value": "absolute" },
      "top":                   { "$type": "dimension", "$value": "{space.0}" },
      "left":                  { "$type": "dimension", "$value": "{space.0}" },
      "width":                 { "$type": "other",     "$value": "100%" },
      "height":                { "$type": "other",     "$value": "100%" },
      "box-shadow":            { "$type": "shadow",    "$value": "{shadow.sm}" },
      "border-radius":         { "$type": "other",     "$value": "inherit" },
      "z-index":               { "$type": "number",    "$value": -1 }
    },

    "header": {
      "font-size":             { "$type": "dimension", "$value": "0.9375rem",
                                 "$description": "15px — between font.size.md (16px) and font.size.sm (14px). Kept as literal pending a font.size.base-minus token." },
      "font-weight":           { "$type": "fontWeight","$value": "{font.weight.regular}" },
      "line-height":           { "$type": "number",    "$value": 1 },
      "min-height":            { "$type": "dimension", "$value": "48px" },
      "min-height-active":     { "$type": "dimension", "$value": "64px" },
      "width":                 { "$type": "other",     "$value": "100%" },
      "border":                { "$type": "other",     "$value": "none" },
      "outline":               { "$type": "other",     "$value": "none" },
      "border-radius":         { "$type": "other",     "$value": "inherit" },
      "hover-overlay-opacity": { "$type": "number",    "$value": "{opacity.0}",
                                 "$description": "calc(0.04 * 1) applied via scoped style" },
      "focus-overlay-opacity": { "$type": "number",    "$value": "{opacity.12}",
                                 "$description": "calc(0.12 * 1) applied via scoped style" },

      "wrapper": {
        "padding-block":       { "$type": "dimension", "$value": "{space.4}" },
        "padding-inline":      { "$type": "dimension", "$value": "{space.6}" },
        "display":             { "$type": "other",     "$value": "flex" },
        "align-items":         { "$type": "other",     "$value": "center" },
        "justify-content":     { "$type": "other",     "$value": "space-between" },
        "transition-duration": { "$type": "duration",  "$value": "{motion.duration.slow}" },
        "transition-easing":   { "$type": "cubicBezier", "$value": "{motion.easing.standard}" }
      },

      "overlay": {
        "position":            { "$type": "other",     "$value": "absolute" },
        "top":                 { "$type": "dimension", "$value": "{space.0}" },
        "left":                { "$type": "dimension", "$value": "{space.0}" },
        "width":               { "$type": "other",     "$value": "100%" },
        "height":              { "$type": "other",     "$value": "100%" },
        "border-radius":       { "$type": "other",     "$value": "inherit" },
        "opacity":             { "$type": "number",    "$value": "{opacity.0}" }
      },

      "prepend": {
        "margin-inline-end":   { "$type": "dimension", "$value": "{space.2}" },
        "margin-block":        { "$type": "dimension", "$value": "-4px",
                                 "$description": "Negative margin to vertically align icons with the wrapper. No space token for negative values." }
      },

      "append": {
        "margin-inline-start": { "$type": "dimension", "$value": "auto" },
        "margin-block":        { "$type": "dimension", "$value": "-4px",
                                 "$description": "Negative margin to vertically align icons with the wrapper." }
      }
    },

    "content": {
      "display":               { "$type": "other",     "$value": "flex" },
      "padding-block-start":   { "$type": "dimension", "$value": "{space.2}" },
      "padding-block-end":     { "$type": "dimension", "$value": "{space.4}" },
      "padding-inline-start":  { "$type": "dimension", "$value": "{space.6}" },
      "padding-inline-end":    { "$type": "dimension", "$value": "{space.6}" },
      "flex":                  { "$type": "other",     "$value": "1 1 auto" },
      "max-width":             { "$type": "other",     "$value": "100%" }
    },

    "accordion": {
      "separator-color":       { "$type": "color",     "$value": "{color.border.subtle}",
                                 "$description": "Border-radius transition in accordion variant applied via scoped style" },
      "header-overlay-transition": { "$type": "duration", "$value": "{motion.duration.slow}" }
    },

    "popout": {
      "max-width":             { "$type": "dimension", "$value": "calc(100% - 32px)" },
      "max-width-active":      { "$type": "dimension", "$value": "calc(100% + 16px)" }
    },

    "inset": {
      "max-width":             { "$type": "other",     "$value": "100%" },
      "max-width-active":      { "$type": "dimension", "$value": "calc(100% - 32px)" }
    }
  }
}
