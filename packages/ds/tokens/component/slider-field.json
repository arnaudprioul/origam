{
  "slider-field": {
    "_comment": "Tokens shared between Slider, RangeSlider, and SliderField (the form-wrapped variant).",
    "padding-block":         { "$type": "dimension", "$value": "{space.2}" },
    "transition-duration":   { "$type": "duration",  "$value": "{motion.duration.fast}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },

    "border-radius": { "$type": "dimension", "$value": "{radius.full}" },

    "track": {
      "height":           { "$type": "dimension", "$value": "4px" },
      "background-color": { "$type": "color",     "$value": "{color.surface.disabled}" },
      "border-radius":    { "$type": "dimension", "$value": "{radius.full}" }
    },

    "track-fill": {
      "background-color":          { "$type": "color", "$value": "{color.action.primary.bg}" },
      "background-color-disabled": { "$type": "color", "$value": "{color.surface.overlay}" },
      "background-color-error":    { "$type": "color", "$value": "{color.feedback.danger.bg}" },
      "transition-duration":       { "$type": "duration", "$value": "{motion.duration.fast}" }
    },

    "thumb": {
      "size":             { "$type": "dimension", "$value": "16px" },
      "background-color": { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "border-color":     { "$type": "color",     "$value": "{color.surface.default}" },
      "border-width":     { "$type": "dimension", "$value": "{border.width.2}" },
      "box-shadow":       { "$type": "shadow",    "$value": "{shadow.sm}" },
      "scale-hover":      { "$type": "number",    "$value": 1.25 },
      "scale-active":     { "$type": "number",    "$value": 1.5 },
      "focus-ring-color": { "$type": "color",     "$value": "{color.action.primary.bgSubtle}" },
      "focus-ring-width": { "$type": "dimension", "$value": "8px" }
    },

    "tick": {
      "size":             { "$type": "dimension", "$value": "4px" },
      "background-color": { "$type": "color",     "$value": "{color.text.disabled}" },
      "background-color-active": { "$type": "color", "$value": "{color.action.primary.fg}" },
      "border-radius":    { "$type": "dimension", "$value": "{radius.full}" }
    },

    "label": {
      "color":     { "$type": "color",      "$value": "{color.text.secondary}" },
      "font-size": { "$type": "dimension",  "$value": "{font.size.sm}" },
      "padding":   { "$type": "dimension",  "$value": "{space.1}" }
    },

    "opacity-disabled": { "$type": "number", "$value": "{opacity.32}" }
  }
}
