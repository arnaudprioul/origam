{
  "select": {
    "_comment": "Select extends TextField for the input chrome. These tokens cover the dropdown menu, items, search input, and chevron.",
    "min-width":  { "$type": "dimension", "$value": "150px" },

    "list": {
      "background-color": { "$type": "color",     "$value": "{color.surface.raised}" },
      "color":            { "$type": "color",     "$value": "{color.text.primary}" },
      "border-radius":    { "$type": "dimension", "$value": "{radius.md}" },
      "max-height":       { "$type": "dimension", "$value": "300px" },
      "padding-block":    { "$type": "dimension", "$value": "{space.1}" },
      "padding-inline":   { "$type": "dimension", "$value": "0" },
      "box-shadow":       { "$type": "shadow",    "$value": "{shadow.lg}" },
      "z-index":          { "$type": "number",    "$value": "{zIndex.dropdown}" }
    },

    "item": {
      "padding-block":    { "$type": "dimension", "$value": "{space.2}" },
      "padding-inline":   { "$type": "dimension", "$value": "{space.4}" },
      "min-height":       { "$type": "dimension", "$value": "40px" },
      "color":            { "$type": "color",     "$value": "{color.text.primary}" },
      "background-color": { "$type": "color",     "$value": "transparent" },
      "background-color-hover":    { "$type": "color", "$value": "{color.surface.overlay}" },
      "background-color-selected": { "$type": "color", "$value": "{color.action.primary.bgSubtle}" },
      "color-selected":    { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "background-color-active": { "$type": "color", "$value": "{color.surface.overlay}" },
      "opacity-disabled":  { "$type": "number",    "$value": "{opacity.32}" },
      "transition-duration": { "$type": "duration", "$value": "{motion.duration.fast}" }
    },

    "no-data": {
      "color":         { "$type": "color",     "$value": "{color.text.secondary}" },
      "padding":       { "$type": "dimension", "$value": "{space.4}" },
      "font-size":     { "$type": "dimension", "$value": "{font.size.sm}" },
      "text-align":    { "$type": "other",     "$value": "center" }
    },

    "chip": {
      "background-color": { "$type": "color",     "$value": "{color.surface.overlay}" },
      "color":            { "$type": "color",     "$value": "{color.text.primary}" },
      "border-radius":    { "$type": "dimension", "$value": "{radius.sm}" },
      "padding-block":    { "$type": "dimension", "$value": "{space.1}" },
      "padding-inline":   { "$type": "dimension", "$value": "{space.2}" },
      "gap":              { "$type": "dimension", "$value": "{space.1}" },
      "max-width":        { "$type": "dimension", "$value": "200px" }
    },

    "chevron": {
      "color":              { "$type": "color",     "$value": "{color.text.secondary}" },
      "color-active":       { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "transition-duration":{ "$type": "duration",  "$value": "{motion.duration.fast}" },
      "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" }
    },

    "search": {
      "background-color": { "$type": "color",     "$value": "{color.surface.sunken}" },
      "padding-block":    { "$type": "dimension", "$value": "{space.2}" },
      "padding-inline":   { "$type": "dimension", "$value": "{space.3}" },
      "border-bottom-color": { "$type": "color",  "$value": "{color.border.subtle}" }
    }
  }
}
