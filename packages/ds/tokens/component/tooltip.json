{
  "tooltip": {
    "background-color": { "$type": "color",     "$value": "{color.neutral.800}",
                          "$description": "Intentionally dark (inverse surface) for contrast in both light and dark themes. In dark theme semantic/dark.json overrides neutral.800 to the correct contrasted surface." },
    "color":            { "$type": "color",     "$value": "{color.text.inverse}" },
    "backdrop-filter":  { "$type": "other",     "$value": "none" },
    "font-size":        { "$type": "dimension", "$value": "{font.size.sm}" },
    "font-weight":      { "$type": "fontWeight", "$value": "{font.weight.medium}" },
    "line-height":      { "$type": "number",    "$value": "{font.lineHeight.normal}" },
    "padding-block":    { "$type": "dimension", "$value": "{space.1}" },
    "padding-inline":   { "$type": "dimension", "$value": "{space.2}" },
    "border-radius":    { "$type": "dimension", "$value": "{radius.sm}" },
    "z-index":          { "$type": "number",    "$value": "{zIndex.tooltip}" },
    "max-width":        { "$type": "dimension", "$value": "300px" },
    "opacity":          { "$type": "number",    "$value": "{opacity.100}" },

    "transition-duration":        { "$type": "duration",    "$value": "{motion.duration.fast}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },

    "arrow": {
      "size":     { "$type": "dimension", "$value": "6px" },
      "position": { "$type": "other",     "$value": "absolute" }
    },

    "top": {
      "offset": { "$type": "dimension", "$value": "{space.2}" }
    },
    "bottom": {
      "offset": { "$type": "dimension", "$value": "{space.2}" }
    },
    "left": {
      "offset": { "$type": "dimension", "$value": "{space.2}" }
    },
    "right": {
      "offset": { "$type": "dimension", "$value": "{space.2}" }
    }
  }
}
