{
  "img": {
    "background-color":      { "$type": "color",     "$value": "{color.surface.overlay}" },
    "color":                 { "$type": "color",     "$value": "{color.text.disabled}" },
    "border-radius":         { "$type": "dimension", "$value": "{radius.none}" },
    "border-radius-rounded": { "$type": "dimension", "$value": "{radius.sm}" },
    "border-radius-circle":  { "$type": "dimension", "$value": "{radius.full}" },
    "transition-duration":   { "$type": "duration",  "$value": "{motion.duration.medium}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },
    "opacity-loading":       { "$type": "number",    "$value": 0 },
    "opacity-loaded":        { "$type": "number",    "$value": 1 },

    "placeholder": {
      "background-color":  { "$type": "color",     "$value": "{color.surface.disabled}" },
      "color":             { "$type": "color",     "$value": "{color.text.secondary}" },
      "font-size":         { "$type": "dimension", "$value": "{font.size.sm}" }
    },

    "error": {
      "background-color":  { "$type": "color",     "$value": "{color.feedback.danger.bgSubtle}" },
      "color":             { "$type": "color",     "$value": "{color.feedback.danger.fgSubtle}" }
    }
  }
}
