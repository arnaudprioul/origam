{
  "chip": {
    "background-color":  { "$type": "color",      "$value": "{color.surface.overlay}" },
    "color":             { "$type": "color",      "$value": "{color.text.primary}" },
    "border-color":      { "$type": "color",      "$value": "currentColor" },
    "border-style":      { "$type": "other",      "$value": "solid" },
    "border-width":      { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-radius":     { "$type": "dimension",  "$value": "{radius.full}" },
    "border-radius-label": { "$type": "dimension","$value": "{radius.sm}" },
    "font-weight":       { "$type": "fontWeight", "$value": "{font.weight.regular}" },
    "opacity-disabled":  { "$type": "number",     "$value": "{opacity.32}" },
    "density":           { "$type": "dimension",  "$value": "0px" },
    "overlay-opacity":         { "$type": "number", "$value": "{opacity.0}" },
    "overlay-opacity-hover":   { "$type": "number", "$value": 0.24 },
    "overlay-opacity-focus":   { "$type": "number", "$value": "{opacity.12}" },
    "overlay-opacity-active":  { "$type": "number", "$value": "{opacity.12}" },
    "transition-duration":     { "$type": "duration",    "$value": "{motion.duration.medium}" },
    "transition-easing":       { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },
    "font-size-xs":  { "$type": "dimension", "$value": "{font.size.xs}" },
    "font-size-sm":  { "$type": "dimension", "$value": "{font.size.sm}" },
    "font-size-md":  { "$type": "dimension", "$value": "{font.size.md}" },
    "font-size-lg":  { "$type": "dimension", "$value": "{font.size.lg}" },
    "font-size-xl":  { "$type": "dimension", "$value": "{font.size.xl}" },
    "padding-xs":    { "$type": "dimension", "$value": "{space.2}" },
    "padding-sm":    { "$type": "dimension", "$value": "10px" },
    "padding-md":    { "$type": "dimension", "$value": "{space.3}" },
    "padding-lg":    { "$type": "dimension", "$value": "14px" },
    "padding-xl":    { "$type": "dimension", "$value": "17px" },
    "selected": {
      "background-color": { "$type": "color", "$value": "{color.action.primary.bg}" },
      "color":            { "$type": "color", "$value": "{color.action.primary.fg}" }
    },
    "success": {
      "background-color": { "$type": "color", "$value": "{color.feedback.success.bgSubtle}" },
      "color":            { "$type": "color", "$value": "{color.feedback.success.fgSubtle}" },
      "border-color":     { "$type": "color", "$value": "{color.feedback.success.border}" }
    },
    "warning": {
      "background-color": { "$type": "color", "$value": "{color.feedback.warning.bgSubtle}" },
      "color":            { "$type": "color", "$value": "{color.feedback.warning.fgSubtle}" },
      "border-color":     { "$type": "color", "$value": "{color.feedback.warning.border}" }
    },
    "danger": {
      "background-color": { "$type": "color", "$value": "{color.feedback.danger.bgSubtle}" },
      "color":            { "$type": "color", "$value": "{color.feedback.danger.fgSubtle}" },
      "border-color":     { "$type": "color", "$value": "{color.feedback.danger.border}" }
    },
    "info": {
      "background-color": { "$type": "color", "$value": "{color.feedback.info.bgSubtle}" },
      "color":            { "$type": "color", "$value": "{color.feedback.info.fgSubtle}" },
      "border-color":     { "$type": "color", "$value": "{color.feedback.info.border}" }
    },
    "outlined": {
      "background-color": { "$type": "color",     "$value": "transparent" },
      "border-width":     { "$type": "dimension",  "$value": "{border.width.thin}" },
      "border-color":     { "$type": "color",      "$value": "currentColor" }
    },
    "overlay": {
      "background-color":          { "$type": "color",      "$value": "{color.overlay.scrim}" },
      "border-radius":             { "$type": "other",      "$value": "inherit" },
      "opacity":                   { "$type": "number",     "$value": "{opacity.0}" },
      "pointer-events":            { "$type": "other",      "$value": "none" },
      "position":                  { "$type": "other",      "$value": "absolute" },
      "position-top":              { "$type": "dimension",  "$value": "{space.0}" },
      "position-left":             { "$type": "dimension",  "$value": "{space.0}" },
      "width":                     { "$type": "other",      "$value": "100%" },
      "height":                    { "$type": "other",      "$value": "100%" },
      "transition-property":       { "$type": "other",      "$value": "opacity" },
      "transition-duration":       { "$type": "duration",   "$value": "{motion.duration.medium}" },
      "transition-timing-function":{ "$type": "cubicBezier","$value": "{motion.easing.standard}" }
    },
    "underlay": {
      "position": { "$type": "other", "$value": "absolute" }
    },
    "close": {
      "cursor":      { "$type": "other",     "$value": "pointer" },
      "font-size":   { "$type": "dimension", "$value": "18px" },
      "max-height":  { "$type": "dimension", "$value": "18px" },
      "max-width":   { "$type": "dimension", "$value": "18px" },
      "user-select": { "$type": "other",     "$value": "none" },
      "flex":        { "$type": "other",     "$value": "0 1 auto" }
    },
    "filter": {
      "transition-property":       { "$type": "other",      "$value": "transform, opacity" },
      "transition-duration":       { "$type": "duration",   "$value": "{motion.duration.normal}" },
      "transition-timing-function":{ "$type": "cubicBezier","$value": "{motion.easing.standard}" }
    }
  }
}
