{
  "rating-field": {
    "_comment": "Star-rating control. The default off color is `text.disabled`; the active color is `feedback.warning.bg` (amber).",
    "gap":                   { "$type": "dimension", "$value": "{space.1}" },
    "transition-duration":   { "$type": "duration",  "$value": "{motion.duration.fast}" },

    "item": {
      "color":           { "$type": "color",      "$value": "{color.text.disabled}" },
      "color-active":    { "$type": "color",      "$value": "{color.feedback.warning.bg}" },
      "color-disabled":  { "$type": "color",      "$value": "{color.text.disabled}" },
      "font-size":       { "$type": "dimension",  "$value": "{font.size.2xl}" },
      "scale-hover":     { "$type": "number",     "$value": 1.15 },
      "scale-active":    { "$type": "number",     "$value": 1.3 },
      "transition-duration":{ "$type": "duration", "$value": "{motion.duration.fast}" }
    },

    "label": {
      "color":      { "$type": "color",     "$value": "{color.text.secondary}" },
      "font-size":  { "$type": "dimension", "$value": "{font.size.sm}" },
      "padding-inline": { "$type": "dimension", "$value": "{space.2}" }
    },

    "opacity-disabled": { "$type": "number", "$value": "{opacity.32}" }
  }
}
