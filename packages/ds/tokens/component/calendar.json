{
  "calendar": {
    "_comment": "Tokens for <OrigamCalendar>. Four views (month/week/day/agenda) share a single token surface — view-specific tweaks (timeline slot height, day-cell height) sit under the BEM child that owns them.",

    "background-color":    { "$type": "color",     "$value": "{color.surface.default}" },
    "border-color":        { "$type": "color",     "$value": "{color.border.default}" },
    "border-radius":       { "$type": "dimension", "$value": "{radius.md}" },
    "border-width":        { "$type": "dimension", "$value": "{border.width.1}" },
    "color":               { "$type": "color",     "$value": "{color.text.primary}" },
    "gap":                 { "$type": "dimension", "$value": "{space.0}" },
    "padding":             { "$type": "dimension", "$value": "{space.0}" },

    "day-cell": {
      "height":              { "$type": "dimension", "$value": "120px" },
      "padding":             { "$type": "dimension", "$value": "{space.2}" },
      "color":               { "$type": "color",     "$value": "{color.text.primary}" },
      "color-muted":         { "$type": "color",     "$value": "{color.text.secondary}" },
      "color-disabled":      { "$type": "color",     "$value": "{color.text.disabled}" },
      "border-color":        { "$type": "color",     "$value": "{color.border.subtle}" },
      "bg-color-today":      { "$type": "color",     "$value": "{color.action.primary.bgSubtle}" },
      "bg-color-weekend":    { "$type": "color",     "$value": "{color.surface.sunken}" },
      "bg-color-outside":    { "$type": "color",     "$value": "{color.surface.sunken}" },
      "bg-color-hover":      { "$type": "color",     "$value": "{color.surface.overlay}" }
    },

    "event": {
      "padding":             { "$type": "dimension", "$value": "{space.1}" },
      "font-size":           { "$type": "dimension", "$value": "{font.size.xs}" },
      "border-radius":       { "$type": "dimension", "$value": "{radius.sm}" },
      "bg-color-default":    { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "color-default":       { "$type": "color",     "$value": "{color.action.primary.fg}" }
    },

    "toolbar": {
      "padding":             { "$type": "dimension", "$value": "{space.3}" },
      "gap":                 { "$type": "dimension", "$value": "{space.2}" },
      "background-color":    { "$type": "color",     "$value": "{color.surface.default}" },
      "border-color":        { "$type": "color",     "$value": "{color.border.subtle}" },
      "title-color":         { "$type": "color",     "$value": "{color.text.primary}" },
      "title-font-size":     { "$type": "dimension", "$value": "{font.size.md}" },
      "title-font-weight":   { "$type": "fontWeight","$value": "{font.weight.semibold}" }
    },

    "timeline": {
      "slot-height":         { "$type": "dimension", "$value": "32px" },
      "hour-label": {
        "color":             { "$type": "color",     "$value": "{color.text.secondary}" },
        "font-size":         { "$type": "dimension", "$value": "{font.size.xs}" },
        "width":             { "$type": "dimension", "$value": "56px" }
      },
      "grid-line-color":     { "$type": "color",     "$value": "{color.border.subtle}" }
    },

    "range-select": {
      "bg-color":            { "$type": "color",     "$value": "{color.action.primary.bgSubtle}" },
      "border-color":        { "$type": "color",     "$value": "{color.action.primary.bg}" }
    },

    "week-number": {
      "color":               { "$type": "color",     "$value": "{color.text.secondary}" },
      "font-size":           { "$type": "dimension", "$value": "{font.size.xs}" },
      "width":               { "$type": "dimension", "$value": "32px" }
    },

    "agenda": {
      "padding":             { "$type": "dimension", "$value": "{space.4}" },
      "row-gap":             { "$type": "dimension", "$value": "{space.3}" },
      "day-color":           { "$type": "color",     "$value": "{color.text.primary}" },
      "day-font-weight":     { "$type": "fontWeight","$value": "{font.weight.semibold}" }
    }
  }
}
