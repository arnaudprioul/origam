{
  "btn": {
    "background-color": { "$type": "color",      "$value": "{color.action.secondary.bg}" },
    "color":            { "$type": "color",      "$value": "{color.action.secondary.fg}" },
    "background-color-hover":   { "$type": "color", "$value": "{color.action.secondary.bgHover}" },
    "background-color-disabled":{ "$type": "color", "$value": "{color.action.primary.bgDisabled}" },
    "color-disabled":           { "$type": "color", "$value": "{color.action.primary.fgDisabled}" },
    "border-radius":     { "$type": "dimension",  "$value": "{radius.sm}" },
    "border-radius-icon":{ "$type": "dimension",  "$value": "{radius.full}" },
    "border-radius-rounded":{ "$type": "dimension","$value": "{radius.2xl}" },
    "border-width":      { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-style":      { "$type": "other",      "$value": "solid" },
    "border-color":      { "$type": "color",      "$value": "currentColor" },
    "position":          { "$type": "other",      "$value": "relative" },
    "density":           { "$type": "dimension",  "$value": "0" },
    "width":             { "$type": "dimension",  "$value": "auto" },
    "min-width":         { "$type": "dimension",  "$value": "64px" },
    "max-width":         { "$type": "dimension",  "$value": "100%" },
    "height":            { "$type": "dimension",  "$value": "36px" },
    "max-height":        { "$type": "dimension",  "$value": "100%" },
    "height-xs":         { "$type": "dimension",  "$value": "20px" },
    "height-sm":         { "$type": "dimension",  "$value": "28px" },
    "height-md":         { "$type": "dimension",  "$value": "36px" },
    "height-lg":         { "$type": "dimension",  "$value": "44px" },
    "height-xl":         { "$type": "dimension",  "$value": "52px" },
    "padding-xs":        { "$type": "dimension",  "$value": "{space.2}" },
    "padding-sm":        { "$type": "dimension",  "$value": "{space.3}" },
    "padding-md":        { "$type": "dimension",  "$value": "{space.4}" },
    "padding-lg":        { "$type": "dimension",  "$value": "{space.5}" },
    "padding-xl":        { "$type": "dimension",  "$value": "{space.6}" },
    "font-size":         { "$type": "dimension",  "$value": "{font.size.md}" },
    "font-weight":       { "$type": "fontWeight", "$value": "{font.weight.medium}" },
    "letter-spacing":    { "$type": "dimension",  "$value": "{font.letterSpacing.widest}" },
    "line-height":       { "$type": "number",     "$value": 1 },
    "text-decoration":   { "$type": "other",      "$value": "none" },
    "text-indent":       { "$type": "dimension",  "$value": "{font.letterSpacing.widest}" },
    "opacity":           { "$type": "number",     "$value": 1 },
    "opacity-disabled":  { "$type": "number",     "$value": "{opacity.50}" },
    "opacity-plain":     { "$type": "number",     "$value": "{opacity.70}" },
    "overlay-opacity-hover":{ "$type": "number",  "$value": "{opacity.12}" },
    "box-shadow-elevated": { "$type": "shadow",   "$value": "{shadow.md}" },
    "background-color-tonal": { "$type": "color", "$value": "{color.surface.overlay}" },
    "border-width-outlined":  { "$type": "dimension","$value": "{border.width.thin}" },
    "border-width-ghost":     { "$type": "dimension","$value": "{border.width.thin}" },
    "backdrop-filter-ghost":  { "$type": "other",    "$value": "blur(8px)" },
    "transition-duration":{ "$type": "duration", "$value": "{motion.duration.slow}" },
    "transition-easing":  { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },
    "primary": {
      "background-color":       { "$type": "color", "$value": "{color.action.primary.bg}" },
      "color":                  { "$type": "color", "$value": "{color.action.primary.fg}" },
      "background-color-hover": { "$type": "color", "$value": "{color.action.primary.bgHover}" }
    },
    "ghost": {
      "background-color":       { "$type": "color", "$value": "{color.action.ghost.bg}" },
      "color":                  { "$type": "color", "$value": "{color.action.ghost.fg}" },
      "background-color-hover": { "$type": "color", "$value": "{color.action.ghost.bgHover}" }
    },
    "success": {
      "background-color": { "$type": "color", "$value": "{color.feedback.success.bg}" },
      "color":            { "$type": "color", "$value": "{color.feedback.success.fg}" }
    },
    "warning": {
      "background-color": { "$type": "color", "$value": "{color.feedback.warning.bg}" },
      "color":            { "$type": "color", "$value": "{color.feedback.warning.fg}" }
    },
    "danger": {
      "background-color": { "$type": "color", "$value": "{color.feedback.danger.bg}" },
      "color":            { "$type": "color", "$value": "{color.feedback.danger.fg}" }
    },
    "info": {
      "background-color": { "$type": "color", "$value": "{color.feedback.info.bg}" },
      "color":            { "$type": "color", "$value": "{color.feedback.info.fg}" }
    }
  }
}
