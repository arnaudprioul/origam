{
  "textarea-field": {
    "_comment": "TextareaField component tokens — Lot 3.2B + rich-text Wave 2. Extends TextField with auto-grow, manual resize grip, row-height management AND a lightweight contenteditable editor (`mode=\"rich\"`).",

    "textarea": {
      "opacity":               { "$type": "number",    "$value": "{opacity.0}" },
      "opacity-active":        { "$type": "number",    "$value": "{opacity.100}" },
      "transition-duration":   { "$type": "duration",  "$value": "0.15s" },
      "transition-easing":     { "$type": "cubicBezier","$value": "{motion.easing.standard}" },
      "line-height":           { "$type": "number",    "$value": 1 }
    },

    "grip": {
      "border-color":          { "$type": "color",     "$value": "{color.border.subtle}",
        "$description": "Replaces legacy `#ddd` fallback (Lot 3.1). `{color.border.subtle}` resolves to neutral.300 in light and its dark-theme counterpart." },
      "opacity":               { "$type": "number",    "$value": "{opacity.26}",
        "$description": "Grip resting opacity (was hardcoded 0.2 — aligned to nearest palette step opacity.26 pending opacity.20 decision from Lot 2D arbitrage)." },
      "height":                { "$type": "dimension", "$value": "9px" }
    },

    "rich-toolbar": {
      "bg-color":              { "$type": "color",     "$value": "{color.surface.sunken}",
        "$description": "Toolbar background — kept tinted vs. the editor surface to draw the boundary in rich mode." },
      "border-color":          { "$type": "color",     "$value": "{color.border.subtle}" },
      "border-radius":         { "$type": "dimension", "$value": "{radius.md}" },
      "padding":               { "$type": "dimension", "$value": "{space.2}" },
      "gap":                   { "$type": "dimension", "$value": "{space.1}" }
    },

    "rich-toolbar-btn": {
      "size":                  { "$type": "dimension", "$value": "32px" },
      "padding":               { "$type": "dimension", "$value": "{space.1}" },
      "border-radius":         { "$type": "dimension", "$value": "{radius.sm}" },
      "bg-color":              { "$type": "color",     "$value": "transparent" },
      "color":                 { "$type": "color",     "$value": "{color.text.primary}" }
    },

    "rich-toolbar-btn-hover": {
      "bg-color":              { "$type": "color",     "$value": "{color.action.ghost.bgHover}" },
      "color":                 { "$type": "color",     "$value": "{color.text.primary}" }
    },

    "rich-toolbar-btn-active": {
      "bg-color":              { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "color":                 { "$type": "color",     "$value": "{color.action.primary.fg}" }
    },

    "rich-toolbar-btn-focus": {
      "outline-color":         { "$type": "color",     "$value": "{color.action.primary.bg}" }
    },

    "rich-content": {
      "padding":               { "$type": "dimension", "$value": "{space.3}" },
      "min-height":            { "$type": "dimension", "$value": "120px" },
      "line-height":           { "$type": "number",    "$value": 1.5 },
      "paragraph-gap":         { "$type": "dimension", "$value": "{space.3}" },
      "placeholder-color":     { "$type": "color",     "$value": "{color.text.secondary}" }
    },

    "rich-code-inline": {
      "bg-color":              { "$type": "color",     "$value": "{color.surface.sunken}" },
      "color":                 { "$type": "color",     "$value": "{color.text.primary}" }
    },

    "rich-link": {
      "color":                 { "$type": "color",     "$value": "{color.action.primary.bg}" },
      "text-decoration":       { "$type": "other",     "$value": "underline" }
    },

    "rich-list": {
      "padding-inline-start":  { "$type": "dimension", "$value": "{space.6}" }
    },

    "rich-heading": {
      "font-size-h1":          { "$type": "dimension", "$value": "1.75rem" },
      "font-size-h2":          { "$type": "dimension", "$value": "1.35rem" },
      "font-size-h3":          { "$type": "dimension", "$value": "1.1rem" }
    }
  }
}
