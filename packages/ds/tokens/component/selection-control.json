{
  "selection-control": {
    "color":                        { "$type": "color",     "$value": "{color.text.primary}" },
    "color-disabled":               { "$type": "color",     "$value": "{color.text.disabled}" },
    "color-error":                  { "$type": "color",     "$value": "{color.feedback.danger.fgSubtle}", "$description": "Couleur du label et de l'icône en état erreur" },
    "opacity-disabled":             { "$type": "number",    "$value": "{opacity.50}", "$description": "Opacité du contrôle entier quand désactivé" },

    "density":                      { "$type": "dimension", "$value": "0px", "$description": "Modificateur de density (surchargé par --density-compact/-default/-comfortable)" },

    "transition-duration":          { "$type": "duration",  "$value": "{motion.duration.medium}" },
    "transition-easing":            { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },

    "wrapper": {
      "width":                      { "$type": "dimension", "$value": "40px", "$description": "Base sans density — calc(40px + 1.5 * var(--density)) dans le SCSS" },
      "height":                     { "$type": "dimension", "$value": "40px" }
    },

    "input": {
      "border-radius":              { "$type": "dimension", "$value": "{radius.full}", "$description": "Ripple zone — cercle complet" },
      "overlay-opacity-hover":      { "$type": "number",    "$value": "{opacity.12}", "$description": "Opacité du ::before au survol" },
      "overlay-opacity-focus":      { "$type": "number",    "$value": "{opacity.12}", "$description": "Opacité du ::before en focus-visible" },
      "overlay-background-color":   { "$type": "color",     "$value": "currentColor", "$description": "Fond de la zone ripple/overlay (currentColor = couleur de l'icône active)" },
      "backdrop-filter":            { "$type": "other",     "$value": "none", "$description": "#253 — matière hook du puits Checkbox/Radio (composant partagé SelectionControl). Le rendu du glyphe (#241, boîte non dessinée en CSS) peut rendre l'effet peu marqué sur un fond majoritairement transparent — vérifié au cas par cas par thème." }
    },

    "icon": {
      "opacity":                    { "$type": "number",    "$value": "{opacity.26}", "$description": "Opacité de l'icône non-sélectionnée — devient 1 si dirty/error/disabled" },
      "opacity-active":             { "$type": "number",    "$value": "{opacity.100}" }
    },

    "label": {
      "color":                      { "$type": "color",     "$value": "{color.text.primary}" },
      "color-error":                { "$type": "color",     "$value": "{color.feedback.danger.fgSubtle}" },
      "opacity-disabled":           { "$type": "number",    "$value": "{opacity.100}", "$description": "Le label n'est PAS assombri par l'opacité du parent en mode erreur/disabled" }
    }
  }
}
