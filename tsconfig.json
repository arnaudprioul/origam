{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "allowJs": true,
    "noEmit": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",

    /* Paths */
    "paths": {
      "@origam": ["./src"],
      "@origam/*": ["./src/*"],
      "@stories": ["./stories"],
      "@stories/*": ["./stories/*"],
      "@docs": ["./docs"],
      "@docs/*": ["./docs/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    ".history",
    "dist/**/*",
    "src/**/*.spec.ts",
    "src/**/*.story.vue",
    "node_modules"
  ],
  "references": [
    { "path": "./tsconfig.node.json" },
//    { "path": "./tsconfig.build.json" },
    { "path": "./stories/tsconfig.json" },
    { "path": "./docs/tsconfig.json" },
    { "path": "./tests/TU/tsconfig.json" },
    { "path": "./tests/e2e/tsconfig.json" }
  ]
}