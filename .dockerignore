# Node / build artefacts (top-level AND nested per-package, so a non-clean
# working tree never leaks host node_modules / build output into the image).
node_modules
**/node_modules
dist
**/dist
dist-ssr
**/.nuxt
**/.output
**/.vitepress/dist
**/.vitepress/cache
**/.histoire
docs/.vitepress/dist
docs/.vitepress/cache
coverage

# VCS / IDE / agent metadata
.git
.gitignore
.github
.idea
.vscode
.claude
.husky

# Local env
.env
.env.*
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Tests output
tests/e2e/.results
tests/e2e/.report
cypress/screenshots
cypress/videos

# OS
.DS_Store
Thumbs.db

# Docker / CI scaffolding (avoid recursive copies). EXCEPTION: nginx.conf must
# stay in the context — Dockerfile.docs / Dockerfile.stories `COPY docker/nginx.conf
# /etc/nginx/nginx.conf`. Excluding the whole `docker` dir removed it from the
# build context, so buildx failed with `"/docker/nginx.conf": not found` — the
# Docker workflow has been red since the monorepo move because of this.
docker/*
!docker/nginx.conf
.dockerignore
Dockerfile*

# Long-form docs not needed in the image
ROADMAP.md
CLAUDE.md
CLAUDE_CODE_BRIEF.md
# NOTE: CHANGELOG.md is consumed at build-time by
# packages/marketing/scripts/parse-changelog.mjs (generates
# .generated/changelog.json which Nitro imports during prerender).
# Do NOT add it back here unless you also stop parsing it in the
# marketing build.

# Misc build artefacts tracked by .gitignore as well
*.tsbuildinfo
maquettes
figma-plugin
