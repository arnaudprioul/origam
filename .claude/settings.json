{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Team-wide permissions for origam. Spawned sub-agents (architect, frontend-lead, frontend-developer, ui-designer, qa-tester, etc.) inherit this allowlist so they can write files and run common commands autonomously without interactive prompts. Personal overrides go in .claude/settings.local.json (gitignored).",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "NotebookEdit",
      "Bash(pwd)",
      "Bash(true)",
      "Bash(false)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(diff *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm tokens/*)",
      "Bash(rm src/*)",
      "Bash(rm dist/*)",
      "Bash(rm -rf dist)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf src/assets/css/tokens)",
      "Bash(rm -rf src/assets/scss/tokens)",
      "Bash(touch *)",
      "Bash(git -C *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rev-parse*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git switch *)",
      "Bash(git config --get *)",
      "Bash(git ls-files*)",
      "Bash(git remote -v)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git flow feature start *)",
      "Bash(git flow feature publish *)",
      "Bash(git flow release start *)",
      "Bash(git flow hotfix start *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm run *)",
      "Bash(npm audit*)",
      "Bash(npm test*)",
      "Bash(npm pack *)",
      "Bash(npm view *)",
      "Bash(npm ls*)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(node --version)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bash -c *)",
      "Bash(source *)",
      "Bash(. ~/.nvm/nvm.sh*)",
      "Bash(nvm *)",
      "Bash(source ~/.nvm/nvm.sh && nvm use *)",
      "Bash(gh *)",
      "Bash(curl -sf *)",
      "Bash(curl -s *)",
      "Skill(update-config)",
      "Skill(simplify)",
      "Skill(review)",
      "Skill(security-review)",
      "Skill(fewer-permission-prompts)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..*)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/master)",
      "Bash(git reset --hard origin/develop)",
      "Bash(git flow feature finish *)",
      "Bash(git flow hotfix finish *)",
      "Bash(npm publish*)",
      "Bash(npm unpublish*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(eval *)",
      "Edit(/etc/*)",
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(/etc/*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(.env)",
      "Write(.env.*)"
    ],
    "additionalDirectories": []
  }
}
