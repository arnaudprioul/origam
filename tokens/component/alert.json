{
  "alert": {
    "background-color":        { "$type": "color",      "$value": "{color.surface.disabled}" },
    "color":                   { "$type": "color",      "$value": "{color.text.primary}" },
    "border-color":            { "$type": "color",      "$value": "transparent" },
    "border-style":            { "$type": "other",      "$value": "solid" },
    "border-top-width":        { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-left-width":       { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-bottom-width":     { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-right-width":      { "$type": "dimension",  "$value": "{border.width.0}" },
    "border-radius":           { "$type": "dimension",  "$value": "{radius.none}" },
    "border-radius-rounded":   { "$type": "dimension",  "$value": "{radius.sm}" },
    "position":                { "$type": "other",      "$value": "static" },
    "padding-block-start":     { "$type": "dimension",  "$value": "{space.4}" },
    "padding-block-end":       { "$type": "dimension",  "$value": "{space.4}" },
    "padding-inline-start":    { "$type": "dimension",  "$value": "{space.4}" },
    "padding-inline-end":      { "$type": "dimension",  "$value": "{space.4}" },
    "margin-block-start":      { "$type": "dimension",  "$value": "{space.0}" },
    "margin-block-end":        { "$type": "dimension",  "$value": "{space.0}" },
    "margin-inline-start":     { "$type": "dimension",  "$value": "{space.0}" },
    "margin-inline-end":       { "$type": "dimension",  "$value": "{space.0}" },
    "density":                 { "$type": "dimension",  "$value": "0px" },
    "accent-width":            { "$type": "dimension",  "$value": "24px" },
    "box-shadow-elevated":     { "$type": "shadow",     "$value": "{shadow.md}" },

    "prepend": {
      "align-items":           { "$type": "other",      "$value": "center" },
      "margin-inline-start":   { "$type": "dimension",  "$value": "{space.0}" },
      "margin-inline-end":     { "$type": "dimension",  "$value": "{space.4}" },
      "margin-block-start":    { "$type": "dimension",  "$value": "{space.0}" },
      "margin-block-end":      { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-start":   { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-end":     { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-start":  { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-end":    { "$type": "dimension",  "$value": "{space.0}" }
    },

    "append": {
      "align-items":           { "$type": "other",      "$value": "center" },
      "margin-inline-start":   { "$type": "dimension",  "$value": "{space.4}" },
      "margin-inline-end":     { "$type": "dimension",  "$value": "{space.0}" },
      "margin-block-start":    { "$type": "dimension",  "$value": "{space.0}" },
      "margin-block-end":      { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-start":   { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-end":     { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-start":  { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-end":    { "$type": "dimension",  "$value": "{space.0}" }
    },

    "close": {
      "margin-inline-start":   { "$type": "dimension",  "$value": "{space.4}" },
      "margin-inline-end":     { "$type": "dimension",  "$value": "{space.0}" },
      "margin-block-start":    { "$type": "dimension",  "$value": "{space.0}" },
      "margin-block-end":      { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-start":   { "$type": "dimension",  "$value": "{space.0}" },
      "padding-block-end":     { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-start":  { "$type": "dimension",  "$value": "{space.0}" },
      "padding-inline-end":    { "$type": "dimension",  "$value": "{space.0}" }
    },

    "title": {
      "align-items":           { "$type": "other",      "$value": "center" },
      "font-size":             { "$type": "dimension",  "$value": "{font.size.2xl}" },
      "font-weight":           { "$type": "fontWeight", "$value": "{font.weight.medium}" },
      "hyphens":               { "$type": "other",      "$value": "auto" },
      "letter-spacing":        { "$type": "dimension",  "$value": "{font.letterSpacing.wider}" },
      "line-height":           { "$type": "number",     "$value": "{font.lineHeight.tight}" },
      "overflow-wrap":         { "$type": "other",      "$value": "normal" },
      "text-transform":        { "$type": "other",      "$value": "none" },
      "word-break":            { "$type": "other",      "$value": "normal" },
      "word-wrap":             { "$type": "other",      "$value": "break-word" }
    },

    "text": {
      "font-size":             { "$type": "dimension",  "$value": "{font.size.lg}" },
      "font-weight":           { "$type": "fontWeight", "$value": "{font.weight.regular}" },
      "line-height":           { "$type": "number",     "$value": "{font.lineHeight.snug}" },
      "letter-spacing":        { "$type": "dimension",  "$value": "{font.letterSpacing.wider}" },
      "hyphens":               { "$type": "other",      "$value": "auto" },
      "word-break":            { "$type": "other",      "$value": "normal" },
      "word-wrap":             { "$type": "other",      "$value": "break-word" }
    },

    "underlay": {
      "border-radius":         { "$type": "dimension",  "$value": "{radius.sm}" }
    },

    "success": {
      "bg":                    { "$type": "color",      "$value": "{color.feedback.success.bg}" },
      "fg":                    { "$type": "color",      "$value": "{color.feedback.success.fg}" },
      "bg-subtle":             { "$type": "color",      "$value": "{color.feedback.success.bgSubtle}" },
      "fg-subtle":             { "$type": "color",      "$value": "{color.feedback.success.fgSubtle}" },
      "border":                { "$type": "color",      "$value": "{color.feedback.success.border}" }
    },
    "warning": {
      "bg":                    { "$type": "color",      "$value": "{color.feedback.warning.bg}" },
      "fg":                    { "$type": "color",      "$value": "{color.feedback.warning.fg}" },
      "bg-subtle":             { "$type": "color",      "$value": "{color.feedback.warning.bgSubtle}" },
      "fg-subtle":             { "$type": "color",      "$value": "{color.feedback.warning.fgSubtle}" },
      "border":                { "$type": "color",      "$value": "{color.feedback.warning.border}" }
    },
    "danger": {
      "bg":                    { "$type": "color",      "$value": "{color.feedback.danger.bg}" },
      "fg":                    { "$type": "color",      "$value": "{color.feedback.danger.fg}" },
      "bg-subtle":             { "$type": "color",      "$value": "{color.feedback.danger.bgSubtle}" },
      "fg-subtle":             { "$type": "color",      "$value": "{color.feedback.danger.fgSubtle}" },
      "border":                { "$type": "color",      "$value": "{color.feedback.danger.border}" }
    },
    "info": {
      "bg":                    { "$type": "color",      "$value": "{color.feedback.info.bg}" },
      "fg":                    { "$type": "color",      "$value": "{color.feedback.info.fg}" },
      "bg-subtle":             { "$type": "color",      "$value": "{color.feedback.info.bgSubtle}" },
      "fg-subtle":             { "$type": "color",      "$value": "{color.feedback.info.fgSubtle}" },
      "border":                { "$type": "color",      "$value": "{color.feedback.info.border}" }
    }
  }
}
