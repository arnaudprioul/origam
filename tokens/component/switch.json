{
  "switch": {
    "_comment": "Track + thumb component. Track size determines hit area; thumb slides between two positions.",
    "transition-duration":   { "$type": "duration",  "$value": "{motion.duration.medium}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },

    "track": {
      "width":            { "$type": "dimension", "$value": "44px" },
      "height":           { "$type": "dimension", "$value": "24px" },
      "border-radius":    { "$type": "dimension", "$value": "{radius.full}" },
      "background-color": { "$type": "color",     "$value": "{color.surface.disabled}" },
      "background-color-checked":  { "$type": "color", "$value": "{color.action.primary.bg}" },
      "background-color-disabled": { "$type": "color", "$value": "{color.surface.disabled}" },
      "background-color-error":    { "$type": "color", "$value": "{color.feedback.danger.bg}" },
      "border-color":     { "$type": "color",     "$value": "transparent" },
      "border-width":     { "$type": "dimension", "$value": "{border.width.0}" }
    },

    "thumb": {
      "size":              { "$type": "dimension", "$value": "20px" },
      "background-color":  { "$type": "color",     "$value": "{color.surface.default}" },
      "background-color-checked":  { "$type": "color", "$value": "{color.surface.default}" },
      "background-color-disabled": { "$type": "color", "$value": "{color.surface.overlay}" },
      "box-shadow":        { "$type": "shadow",    "$value": "{shadow.sm}" },
      "border-radius":     { "$type": "dimension", "$value": "{radius.full}" },
      "translate-distance":{ "$type": "dimension", "$value": "20px" },
      "transition-duration":{ "$type": "duration", "$value": "{motion.duration.medium}" }
    },

    "label": {
      "color":         { "$type": "color",      "$value": "{color.text.primary}" },
      "color-disabled":{ "$type": "color",      "$value": "{color.text.disabled}" },
      "color-error":   { "$type": "color",      "$value": "{color.feedback.danger.fgSubtle}" },
      "font-size":     { "$type": "dimension",  "$value": "{font.size.md}" },
      "padding-inline":{ "$type": "dimension",  "$value": "{space.2}" }
    },

    "input": {
      "opacity": { "$type": "number", "$value": 0 }
    },

    "opacity-disabled":  { "$type": "number", "$value": "{opacity.32}" }
  }
}
