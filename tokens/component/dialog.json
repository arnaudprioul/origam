{
  "dialog": {
    "background":         { "$type": "color",     "$value": "{color.surface.raised}" },
    "color":              { "$type": "color",     "$value": "{color.text.primary}" },
    "border-radius":      { "$type": "dimension", "$value": "{radius.lg}" },
    "max-width":          { "$type": "dimension", "$value": "calc(100% - 48px)" },
    "max-height":         { "$type": "dimension", "$value": "calc(100% - 48px)" },
    "z-index":            { "$type": "number",    "$value": "{zIndex.modal}" },
    "box-shadow":         { "$type": "shadow",    "$value": "{shadow.xl}" },

    "transition-duration":        { "$type": "duration",    "$value": "{motion.duration.medium}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.decelerate}" },

    "header": {
      "padding":             { "$type": "dimension", "$value": "{space.4}" },
      "gap":                 { "$type": "dimension", "$value": "{space.3}" },
      "border-bottom-color": { "$type": "color",     "$value": "{color.border.subtle}" }
    },

    "content": {
      "padding-block":   { "$type": "dimension", "$value": "{space.4}" },
      "padding-inline":  { "$type": "dimension", "$value": "{space.6}" },
      "font-size":       { "$type": "dimension", "$value": "{font.size.md}" }
    },

    "actions": {
      "padding":          { "$type": "dimension", "$value": "{space.4}" },
      "gap":              { "$type": "dimension", "$value": "{space.2}" },
      "justify-content":  { "$type": "other",     "$value": "flex-end" }
    },

    "close": {
      "position": { "$type": "other", "$value": "absolute" },
      "color":    { "$type": "color", "$value": "{color.text.secondary}" }
    },

    "fullscreen": {
      "border-radius": { "$type": "dimension", "$value": "{radius.none}" },
      "max-width":     { "$type": "other",     "$value": "100%" },
      "max-height":    { "$type": "other",     "$value": "100%" }
    }
  }
}
