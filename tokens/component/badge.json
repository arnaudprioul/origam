{
  "badge": {
    "bg":              { "$type": "color", "$value": "{color.action.primary.bg}" },
    "fg":              { "$type": "color", "$value": "{color.action.primary.fg}" },
    "border-color":    { "$type": "color", "$value": "{color.surface.default}" },
    "border-width":    { "$type": "dimension", "$value": "{border.width.0}" },
    "radius":          { "$type": "dimension", "$value": "{radius.full}" },
    "shadow":          { "$type": "shadow", "$value": "{shadow.none}" },
    "shadow-elevated": { "$type": "shadow", "$value": "{shadow.md}" },
    "font-size":       { "$type": "dimension", "$value": "{font.size.xs}" },
    "font-weight":     { "$type": "fontWeight", "$value": "{font.weight.medium}" },
    "height":          { "$type": "dimension", "$value": "18px" },
    "min-width":       { "$type": "dimension", "$value": "18px" },
    "padding-inline":  { "$type": "dimension", "$value": "{space.1}" },
    "dot-size":        { "$type": "dimension", "$value": "9px" },
    "dot-radius":      { "$type": "dimension", "$value": "{radius.xs}" },
    "success": {
      "bg":            { "$type": "color", "$value": "{color.feedback.success.bg}" },
      "fg":            { "$type": "color", "$value": "{color.feedback.success.fg}" }
    },
    "warning": {
      "bg":            { "$type": "color", "$value": "{color.feedback.warning.bg}" },
      "fg":            { "$type": "color", "$value": "{color.feedback.warning.fg}" }
    },
    "danger": {
      "bg":            { "$type": "color", "$value": "{color.feedback.danger.bg}" },
      "fg":            { "$type": "color", "$value": "{color.feedback.danger.fg}" }
    },
    "info": {
      "bg":            { "$type": "color", "$value": "{color.feedback.info.bg}" },
      "fg":            { "$type": "color", "$value": "{color.feedback.info.fg}" }
    }
  }
}
