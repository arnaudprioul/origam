{
  "grids": {
    "_comment": "Bootstrap-style 12-column grid. Container max-widths align with the breakpoints exposed by useDisplay() so layout decisions stay consistent across CSS and JS.",

    "container": {
      "max-width-sm":   { "$type": "dimension", "$value": "576px" },
      "max-width-md":   { "$type": "dimension", "$value": "768px" },
      "max-width-lg":   { "$type": "dimension", "$value": "992px" },
      "max-width-xl":   { "$type": "dimension", "$value": "1280px" },
      "max-width-xxl":  { "$type": "dimension", "$value": "1440px" },
      "padding-inline": { "$type": "dimension", "$value": "{space.4}" },
      "margin-inline":  { "$type": "other",     "$value": "auto" }
    },

    "row": {
      "gap-none":        { "$type": "dimension", "$value": "{space.0}" },
      "gap-dense":       { "$type": "dimension", "$value": "{space.2}" },
      "gap-default":     { "$type": "dimension", "$value": "{space.4}" },
      "gap-comfortable": { "$type": "dimension", "$value": "{space.6}" },
      "margin-inline":   { "$type": "dimension", "$value": "0" }
    },

    "col": {
      "padding-inline-start": { "$type": "dimension", "$value": "{space.2}" },
      "padding-inline-end":   { "$type": "dimension", "$value": "{space.2}" },
      "padding-block-start":  { "$type": "dimension", "$value": "{space.2}" },
      "padding-block-end":    { "$type": "dimension", "$value": "{space.2}" }
    },

    "spacer": {
      "flex-grow": { "$type": "number",    "$value": 1 },
      "min-size":  { "$type": "dimension", "$value": "{space.0}" }
    }
  }
}
