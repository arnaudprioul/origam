{
  "treeview": {
    "background-color":   { "$type": "color",     "$value": "{color.surface.default}" },
    "color":              { "$type": "color",     "$value": "{color.text.primary}" },
    "padding-block":      { "$type": "dimension", "$value": "{space.1}" },
    "padding-inline":     { "$type": "dimension", "$value": "{space.2}" },
    "indent-size":        { "$type": "dimension", "$value": "{space.4}" },
    "row-height":         { "$type": "dimension", "$value": "{space.8}" },
    "row-gap":            { "$type": "dimension", "$value": "{space.2}" },
    "row-padding-inline": { "$type": "dimension", "$value": "{space.2}" },
    "row-bg-hover":       { "$type": "color",     "$value": "{color.surface.overlay}" },
    "row-bg-selected":    { "$type": "color",     "$value": "{color.action.primary.bgSubtle}" },
    "row-color-selected": { "$type": "color",     "$value": "{color.action.primary.fgSubtle}" },
    "row-color-disabled": { "$type": "color",     "$value": "{color.text.disabled}" },
    "chevron-size":       { "$type": "dimension", "$value": "{space.4}" },
    "chevron-color":      { "$type": "color",     "$value": "{color.text.secondary}" },
    "icon-size":          { "$type": "dimension", "$value": "{space.4}" },
    "icon-color":         { "$type": "color",     "$value": "{color.text.primary}" },
    "label-font-size":    { "$type": "dimension", "$value": "{font.size.sm}" },
    "label-color":        { "$type": "color",     "$value": "{color.text.primary}" },
    "size-font-size":     { "$type": "dimension", "$value": "{font.size.xs}" },
    "size-color":         { "$type": "color",     "$value": "{color.text.secondary}" },
    "guide-color":        { "$type": "color",     "$value": "{color.border.subtle}" },
    "guide-thickness":    { "$type": "dimension", "$value": "{border.width.thin}" }
  }
}
