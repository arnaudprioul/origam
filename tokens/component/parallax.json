{
  "parallax": {
    "aspect-ratio":          { "$type": "other",       "$value": "16 / 9" },
    "transition-duration":   { "$type": "duration",    "$value": "{motion.duration.slow}" },
    "transition-timing-function": { "$type": "cubicBezier", "$value": "{motion.easing.standard}" },
    "perspective":           { "$type": "other",       "$value": "1000px" },
    "transform-origin":      { "$type": "other",       "$value": "center center" },
    "translate-multiplier":  { "$type": "number",      "$value": 0.5 },

    "element": {
      "transition-duration":  { "$type": "duration",   "$value": "{motion.duration.medium}" }
    }
  }
}
