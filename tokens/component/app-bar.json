{
  "app-bar": {
    "background-color":  { "$type": "color",     "$value": "{color.surface.raised}" },
    "color":             { "$type": "color",     "$value": "{color.text.primary}" },
    "border-color":      { "$type": "color",     "$value": "{color.border.subtle}" },
    "box-shadow":        { "$type": "shadow",    "$value": "{shadow.sm}" },
    "height":            { "$type": "dimension", "$value": "64px" },
    "z-index":           { "$type": "number",    "$value": "{zIndex.fixed}" },
    "transition-duration":  { "$type": "duration",     "$value": "{motion.duration.medium}" },
    "transition-easing":    { "$type": "cubicBezier",  "$value": "{motion.easing.standard}" },
    "img": {
      "height":           { "$type": "other",    "$value": "100%" },
      "width":            { "$type": "other",    "$value": "100%" },
      "object-fit":       { "$type": "other",    "$value": "cover" }
    }
  }
}
