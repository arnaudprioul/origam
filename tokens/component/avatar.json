{
  "avatar": {
    "bg":              { "$type": "color", "$value": "{color.surface.overlay}" },
    "fg":              { "$type": "color", "$value": "{color.text.secondary}" },
    "border-color":    { "$type": "color", "$value": "{color.border.subtle}" },
    "border-width":    { "$type": "dimension", "$value": "{border.width.0}" },
    "radius":          { "$type": "dimension", "$value": "{radius.full}" },
    "radius-rounded":  { "$type": "dimension", "$value": "{radius.sm}" },
    "shadow":          { "$type": "shadow", "$value": "{shadow.none}" },
    "shadow-elevated": { "$type": "shadow", "$value": "{shadow.md}" },
    "size-xs":         { "$type": "dimension", "$value": "24px" },
    "size-sm":         { "$type": "dimension", "$value": "32px" },
    "size-md":         { "$type": "dimension", "$value": "40px" },
    "size-lg":         { "$type": "dimension", "$value": "56px" },
    "size-xl":         { "$type": "dimension", "$value": "72px" },
    "font-size":       { "$type": "dimension", "$value": "{font.size.md}" },
    "font-weight":     { "$type": "fontWeight", "$value": "{font.weight.medium}" }
  }
}
