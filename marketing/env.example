# origam marketing — environment variables
# Copy to .env (local) or set them in Coolify UI (deploy).
# NOTE: file is named env.example (no dot) because tooling restricts writes
# to dotfiles. Symlink or rename to .env.example as needed.

# --- Deployment ---
TRAEFIK_HOST=origam.dev.elysera.net
NODE_ENV=production

# --- Site identity ---
NUXT_PUBLIC_SITE_URL=https://origam.dev.elysera.net
NUXT_PUBLIC_GITHUB_REPO=arnaudprioul/origam
NUXT_PUBLIC_NPM_PKG=origam
NUXT_PUBLIC_NPM_VERSION=2.5.1
NUXT_PUBLIC_CONTACT_EMAIL=

# --- Analytics (Plausible) ---
# Leave both empty to disable tracking — useAnalytics becomes a no-op
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=
NUXT_PUBLIC_PLAUSIBLE_API_HOST=
